<view class="container">
  <view class="header">
    <text class="page-title">修改密码</text>
    <text class="page-desc">设置4-6位数字密码，方便快捷登录</text>
  </view>

  <view class="form-section">
    <!-- 旧密码 -->
    <view class="form-item">
      <text class="label">旧密码</text>
      <input class="input" type="number" password="true" placeholder="请输入旧密码" value="{{oldPassword}}" bindinput="onOldPasswordInput"/>
    </view>

    <!-- 新密码 -->
    <view class="form-item">
      <text class="label">新密码</text>
      <input class="input" type="number" password="true" placeholder="请输入4-6位新密码" value="{{newPassword}}" bindinput="onNewPasswordInput" maxlength="6"/>
    </view>

    <!-- 确认密码 -->
    <view class="form-item">
      <text class="label">确认新密码</text>
      <input class="input" type="number" password="true" placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" maxlength="6"/>
    </view>

    <!-- 提交按钮 -->
    <button class="submit-btn" bindtap="handleSubmit">确认修改</button>
  </view>
</view>
