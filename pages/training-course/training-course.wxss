/* 页面容器 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

/* 进度提示 */
.progress-tip {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.3);
}

.tip-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 教程列表 */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.course-item {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.course-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.course-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.course-status {
  font-size: 24rpx;
  color: #999;
}

.view-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: linear-gradient(135deg, #1890ff 0%, #0066cc 100%);
  color: #fff;
  font-size: 26rpx;
  border-radius: 10rpx;
  border: none;
  padding: 0;
}

.view-btn::after {
  border: none;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 考试按钮 */
.exam-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
  margin-top: 20rpx;
}

.exam-btn.disabled {
  background: linear-gradient(135deg, #ccc 0%, #999 100%);
  box-shadow: none;
}

.exam-btn::after {
  border: none;
}

/* 跳过按钮 */
.skip-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a52 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.3);
  margin-top: 20rpx;
}

.skip-btn::after {
  border: none;
}
