<view class="mine-container">
  <!-- 顶部用户信息 -->
  <view class="profile-section">
    <view class="profile-card" bindtap="goToProfile">
      <view class="avatar-wrapper">
        <view class="avatar">
          <text class="avatar-text">{{userName ? userName[0] : '我'}}</text>
        </view>
        <view class="role-badge" wx:if="{{userType === 'volunteer'}}">志愿者</view>
        <view class="role-badge disabled" wx:else>视障跑者</view>
      </view>
      <view class="profile-info">
        <view class="name-row">
          <text class="user-name">{{userName}}</text>
          <!-- 性别标记 -->
          <view class="gender-badge {{userInfo.gender === 'male' ? 'male' : 'female'}}" wx:if="{{userInfo.gender}}">
            <text class="gender-icon">{{userInfo.gender === 'male' ? '♂' : '♀'}}</text>
            <text class="gender-text">{{userInfo.gender === 'male' ? '男' : '女'}}</text>
          </view>
          <view class="tier-badge" wx:if="{{tier}}" style="background: {{tier.color}};">
            <text class="tier-icon">{{tier.icon}}</text>
            <text class="tier-name">{{tier.name}}</text>
          </view>
        </view>
        <text class="user-id">ID: {{userInfo.phone || '未设置'}}</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 任务中心（志愿者专属/未完成时显示） -->
  <view class="task-center-section" wx:if="{{userType === 'volunteer' && !allTasksCompleted}}">
    <view class="task-header">
      <text class="task-title">📋 任务中心</text>
      <text class="task-subtitle">完成以下任务即可开始接单</text>
    </view>

    <!-- 线性任务流程 -->
    <view class="task-flow">
      <!-- 任务1：填写简历 -->
      <view class="task-item {{taskFlow.resumeCompleted ? 'completed' : 'active'}}">
        <view class="task-icon">
          <text wx:if="{{taskFlow.resumeCompleted}}">✓</text>
          <text wx:else>1</text>
        </view>
        <view class="task-content">
          <text class="task-name">填写个人简历</text>
          <text class="task-status" wx:if="{{taskFlow.resumeCompleted}}">已完成</text>
          <text class="task-status pending" wx:else>待完成</text>
        </view>
      </view>

      <!-- 连接线 -->
      <view class="task-line {{taskFlow.resumeCompleted ? 'completed' : ''}}"></view>

      <!-- 任务2：观看教程 -->
      <view class="task-item {{taskFlow.videoCompleted ? 'completed' : (taskFlow.resumeCompleted ? 'active' : '')}}">
        <view class="task-icon">
          <text wx:if="{{taskFlow.videoCompleted}}">✓</text>
          <text wx:else>2</text>
        </view>
        <view class="task-content">
          <text class="task-name">观看培训教程</text>
          <text class="task-status" wx:if="{{taskFlow.videoCompleted}}">已完成</text>
          <text class="task-status pending" wx:else>待完成</text>
        </view>
      </view>

      <!-- 连接线 -->
      <view class="task-line {{taskFlow.videoCompleted ? 'completed' : ''}}"></view>

      <!-- 任务3：通过考试 -->
      <view class="task-item {{taskFlow.examPassed ? 'completed' : (taskFlow.videoCompleted ? 'active' : '')}}">
        <view class="task-icon">
          <text wx:if="{{taskFlow.examPassed}}">✓</text>
          <text wx:else>3</text>
        </view>
        <view class="task-content">
          <text class="task-name">通过在线考试</text>
          <text class="task-status" wx:if="{{taskFlow.examPassed}}">已通过</text>
          <text class="task-status pending" wx:else>待完成</text>
        </view>
      </view>

      <!-- 连接线 -->
      <view class="task-line {{taskFlow.examPassed ? 'completed' : ''}}"></view>

      <!-- 任务4：领取证书 -->
      <view class="task-item {{taskFlow.certificateObtained ? 'completed' : (taskFlow.examPassed ? 'active' : '')}}">
        <view class="task-icon">
          <text wx:if="{{taskFlow.certificateObtained}}">🏆</text>
          <text wx:else>4</text>
        </view>
        <view class="task-content">
          <text class="task-name">领取志愿者证书</text>
          <text class="task-status" wx:if="{{taskFlow.certificateObtained}}">已获得</text>
          <text class="task-status pending" wx:else>待完成</text>
        </view>
      </view>
    </view>

    <!-- 前往完成任务按钮 -->
    <button class="task-btn" bindtap="goToNextTask">
      {{taskFlow.resumeCompleted ? (taskFlow.videoCompleted ? (taskFlow.examPassed ? '查看证书' : '前往考试') : '观看教程') : '填写简历'}}
    </button>
  </view>

  <!-- 已完成任务提示 -->
  <view class="tasks-completed-section" wx:if="{{userType === 'volunteer' && allTasksCompleted}}">
    <view class="completed-badge">
      <text class="completed-icon">🎉</text>
      <text class="completed-text">您已完成所有任务，可以开始接单了！</text>
    </view>
  </view>

  <!-- 视障人士任务提示 -->
  <view class="task-center-section" wx:if="{{userType === 'disabled' && !taskFlow.resumeCompleted}}">
    <view class="task-header">
      <text class="task-title">📋 完善信息</text>
      <text class="task-subtitle">请完善您的个人信息以开始使用</text>
    </view>
    <button class="task-btn" bindtap="goToNextTask">填写个人信息</button>
  </view>

  <!-- 积分和经验值 -->
  <view class="points-section">
    <view class="points-card">
      <view class="points-item">
        <text class="points-value">{{userPoints}}</text>
        <text class="points-label">当前积分</text>
      </view>
      <view class="points-divider"></view>
      <view class="points-item">
        <text class="points-value">{{userExp}}</text>
        <text class="points-label">累计经验</text>
      </view>
      <view class="points-divider"></view>
      <view class="points-item">
        <text class="points-value">{{stats.totalRuns}}</text>
        <text class="points-label">运动次数</text>
      </view>
    </view>
  </view>

  <!-- 运动月报入口 -->
  <view class="report-section" bindtap="goToMonthlyReport">
    <view class="report-card">
      <view class="report-icon">📊</view>
      <view class="report-info">
        <text class="report-title">运动月报</text>
        <text class="report-desc">查看本月的运动数据报告</text>
      </view>
      <text class="report-arrow">></text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-card">
      <view class="menu-item" bindtap="goToProfile">
        <view class="menu-left">
          <text class="menu-icon">👤</text>
          <text class="menu-text">个人信息</text>
        </view>
        <text class="menu-arrow">></text>
      </view>

      <view class="menu-item" wx:if="{{userType === 'volunteer'}}" bindtap="goToCertificate">
        <view class="menu-left">
          <text class="menu-icon">📜</text>
          <text class="menu-text">我的证书</text>
        </view>
        <text class="menu-arrow">></text>
      </view>

      <view class="menu-item" wx:if="{{userType === 'volunteer'}}" bindtap="goToTraining">
        <view class="menu-left">
          <text class="menu-icon">📚</text>
          <text class="menu-text">培训教程</text>
        </view>
        <text class="menu-arrow">></text>
      </view>

      <view class="menu-item" wx:if="{{userType === 'volunteer'}}" bindtap="goToFrequentlyContacted">
        <view class="menu-left">
          <text class="menu-icon">👥</text>
          <text class="menu-text">经常联系的朋友</text>
        </view>
        <text class="menu-arrow">></text>
      </view>

      <view class="menu-item" bindtap="goToRecords">
        <view class="menu-left">
          <text class="menu-icon">📋</text>
          <text class="menu-text">跑步历史</text>
        </view>
        <text class="menu-arrow">></text>
      </view>

      <view class="menu-item" bindtap="goToSchedule">
        <view class="menu-left">
          <text class="menu-icon">📅</text>
          <text class="menu-text">我的日程</text>
        </view>
        <text class="menu-arrow">></text>
      </view>

      <view class="menu-item" bindtap="goToShop">
        <view class="menu-left">
          <text class="menu-icon">🛍️</text>
          <text class="menu-text">积分商城</text>
        </view>
        <view class="menu-right">
          <text class="points-badge" wx:if="{{userPoints > 0}}">{{userPoints}}分</text>
          <text class="menu-arrow">></text>
        </view>
      </view>

      <view class="menu-item" bindtap="goToChangePassword">
        <view class="menu-left">
          <text class="menu-icon">🔑</text>
          <text class="menu-text">修改密码</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 运动数据统计 -->
  <view class="stats-section">
    <view class="stats-card">
      <view class="stats-header">
        <text class="stats-title">运动数据</text>
      </view>
      <view class="stats-grid">
        <view class="stats-item">
          <text class="stats-value">{{stats.totalDistance}}</text>
          <text class="stats-label">总里程(km)</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{stats.totalTime}}</text>
          <text class="stats-label">运动时长(h)</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{stats.totalRuns}}</text>
          <text class="stats-label">运动次数</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</view>
