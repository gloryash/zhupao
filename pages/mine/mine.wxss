/* 我的页面容器 */
.mine-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%);
  padding: 0 30rpx 100rpx;
}

/* 顶部用户信息 */
.profile-section {
  padding-top: 40rpx;
  margin-bottom: 30rpx;
}

.profile-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.avatar-wrapper {
  position: relative;
  margin-right: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 56rpx;
  color: #fff;
  font-weight: bold;
}

.role-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.role-badge.disabled {
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
}

.profile-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.tier-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.tier-icon {
  font-size: 24rpx;
}

.tier-name {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
}

/* 性别标记 */
.gender-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}

.gender-badge.male {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  color: #1976D2;
}

.gender-badge.female {
  background: linear-gradient(135deg, #FCE4EC 0%, #F8BBD9 100%);
  color: #C2185B;
}

.gender-icon {
  font-size: 24rpx;
  font-weight: bold;
}

.gender-text {
  font-weight: 500;
}

.user-id {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 积分和经验值 */
.points-section {
  margin-bottom: 30rpx;
}

.points-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.points-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.points-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.points-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 运动月报入口 */
.report-section {
  margin-bottom: 30rpx;
}

.report-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.report-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.report-info {
  flex: 1;
}

.report-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.report-desc {
  font-size: 24rpx;
  color: #999;
}

.report-arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 功能菜单 */
.menu-section {
  margin-bottom: 30rpx;
}

.menu-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 运动数据统计 */
.stats-section {
  margin-bottom: 40rpx;
}

.stats-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stats-header {
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
}

/* 退出登录 */
.logout-section {
  padding: 20rpx 0;
}

.logout-btn {
  width: 100%;
  height: 100rpx;
  background: #fff;
  color: #ef4444;
  font-size: 32rpx;
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.logout-btn::after {
  border: none;
}

/* ==================== 任务中心 ==================== */
.task-center-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.task-header {
  margin-bottom: 24rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.task-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.task-flow {
  padding: 16rpx 0;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.task-item.active .task-icon {
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C00 100%);
  color: #FFFFFF;
}

.task-item.completed .task-icon {
  background: linear-gradient(135deg, #52C41A 0%, #389E0D 100%);
  color: #FFFFFF;
}

.task-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #E0E0E0;
  color: #999;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.task-content {
  flex: 1;
}

.task-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.task-status {
  font-size: 24rpx;
  color: #52C41A;
}

.task-status.pending {
  color: #FF6B00;
}

.task-line {
  width: 4rpx;
  height: 24rpx;
  background: #E0E0E0;
  margin-left: 22rpx;
  margin-bottom: 8rpx;
}

.task-line.completed {
  background: linear-gradient(180deg, #52C41A 0%, #389E0D 100%);
}

.task-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C00 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  margin-top: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.3);
}

.task-btn::after {
  border: none;
}

/* 已完成任务提示 */
.tasks-completed-section {
  background: linear-gradient(135deg, #F6FFED 0%, #D9F7BE 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #B7EB8F;
}

.completed-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.completed-icon {
  font-size: 40rpx;
}

.completed-text {
  font-size: 28rpx;
  color: #389E0D;
  font-weight: 500;
}
