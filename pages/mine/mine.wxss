/* =========================================================
   Mine · Editorial Light Theme
   白底 / 暖橙强调 (与 tabBar #FF6B00、home 页统一)
   去除紫色渐变 AI 感，统一线性图标 + 发丝边框 + 大数字
   ========================================================= */

page {
  background: #FFFFFF;
}

.mine-container {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 0 28rpx 140rpx;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-feature-settings: 'tnum' 1;
}

/* ---------- 顶部用户名片 ---------- */
.profile-section {
  padding-top: 32rpx;
  margin-bottom: 24rpx;
}

.profile-card {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.profile-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #FF6B00 30%, #FF6B00 70%, transparent);
  opacity: 0.8;
}

.avatar-wrapper {
  position: relative;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 10rpx;
  background: #FFF4EC;
  border: 1rpx solid rgba(255, 107, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 52rpx;
  color: #FF6B00;
  font-weight: 800;
}

.role-badge {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #FF6B00;
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 0, 0.3);
}

.role-badge.disabled {
  background: #1A1A1A;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.user-name {
  font-size: 38rpx;
  font-weight: 900;
  color: #1A1A1A;
  letter-spacing: -0.5rpx;
}

/* 段位徽章 */
.tier-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: #FFF4EC;
  border: 1rpx solid #FF6B00;
  padding: 6rpx 14rpx;
  border-radius: 4rpx;
}

.tier-icon { width: 26rpx; height: 26rpx; flex-shrink: 0; }

.tier-name {
  font-size: 22rpx;
  color: #FF6B00;
  font-weight: 800;
  letter-spacing: 1rpx;
}

/* 性别标记 */
.gender-badge {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 5rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
}

.gender-badge.male { background: #EEF4FB; color: #3B6FB0; }

.gender-badge.female { background: #FBEEF3; color: #B0507E; }

.gender-icon { font-size: 22rpx; font-weight: bold; }

.gender-text { font-weight: 500; }

.user-id {
  font-size: 22rpx;
  color: #9CA3AF;
  letter-spacing: 0.5rpx;
}

.arrow {
  font-size: 40rpx;
  color: #C7C7CC;
  font-weight: 300;
}

/* ---------- 积分 / 经验 / 次数 ---------- */
.points-section { margin-bottom: 24rpx; }

.points-card {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 40rpx 24rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.points-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #FF6B00 30%, #FF6B00 70%, transparent);
  opacity: 0.8;
}

.points-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.points-value {
  font-size: 60rpx;
  font-weight: 900;
  color: #1A1A1A;
  line-height: 1;
  letter-spacing: -1rpx;
}

.points-value.accent { color: #FF6B00; }

.points-label {
  font-size: 20rpx;
  color: #9CA3AF;
  letter-spacing: 2rpx;
}

.points-divider {
  width: 1rpx;
  height: 64rpx;
  background: #F0F0F0;
}

/* ---------- 运动月报入口 ---------- */
.report-section { margin-bottom: 24rpx; }

.report-card {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-left: 4rpx solid #FF6B00;
  border-radius: 10rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.report-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

.report-info { flex: 1; }

.report-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1A1A1A;
  display: block;
}

.report-desc {
  font-size: 22rpx;
  color: #9CA3AF;
}

.report-arrow {
  font-size: 36rpx;
  color: #C7C7CC;
  font-weight: 300;
}

/* ---------- 功能菜单 ---------- */
.menu-section { margin-bottom: 24rpx; }

.menu-card {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
  transition: background 0.15s;
}

.menu-item:last-child { border-bottom: none; }

.menu-item:active { background: #FFF4EC; }

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.menu-text {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-arrow {
  font-size: 40rpx;
  color: #C7C7CC;
  font-weight: 300;
}

.points-badge {
  font-size: 20rpx;
  color: #FF6B00;
  background: #FFF4EC;
  border: 1rpx solid rgba(255, 107, 0, 0.25);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-weight: 700;
}

/* ---------- 运动数据统计 ---------- */
.stats-section { margin-bottom: 24rpx; }

.stats-card {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.stats-header { margin-bottom: 28rpx; }

.stats-title {
  font-size: 24rpx;
  font-weight: 800;
  color: #1A1A1A;
  letter-spacing: 3rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  gap: 10rpx;
}

.stats-value {
  font-size: 46rpx;
  font-weight: 900;
  color: #1A1A1A;
  line-height: 1;
  letter-spacing: -1rpx;
}

.stats-label {
  font-size: 20rpx;
  color: #9CA3AF;
  letter-spacing: 1rpx;
}

/* ---------- 退出登录 ---------- */
.logout-section { padding: 8rpx 0; }

.logout-btn {
  width: 100%;
  height: 96rpx;
  background: #FFFFFF;
  color: #FF4D2E;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  border-radius: 12rpx;
  border: 1rpx solid #EEEEEE;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.logout-btn::after { border: none; }

.logout-btn:active { background: #FAFAF7; }

/* ==================== 任务中心 ==================== */
.task-center-section {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.task-header { margin-bottom: 24rpx; }

.task-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1A1A1A;
  display: block;
}

.task-subtitle {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
  display: block;
}

.task-flow { padding: 16rpx 0; }

.task-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.task-item.active .task-icon {
  background: #FF6B00;
  color: #FFFFFF;
  border-color: #FF6B00;
}

.task-item.completed .task-icon {
  background: #FFF4EC;
  color: #FF6B00;
  border-color: #FF6B00;
}

.task-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F5F5F5;
  border: 1rpx solid #E5E5E5;
  color: #9CA3AF;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.task-content { flex: 1; }

.task-name {
  font-size: 28rpx;
  color: #1A1A1A;
  display: block;
}

.task-status {
  font-size: 22rpx;
  color: #FF6B00;
}

.task-status.pending { color: #9CA3AF; }

.task-line {
  width: 2rpx;
  height: 24rpx;
  background: #E5E5E5;
  margin-left: 23rpx;
  margin-bottom: 6rpx;
}

.task-line.completed { background: #FF6B00; }

.task-btn {
  width: 100%;
  height: 88rpx;
  background: #FF6B00;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  border-radius: 10rpx;
  border: none;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 0, 0.25);
}

.task-btn::after { border: none; }

.task-btn:active { background: #E55F00; }

/* 已完成任务提示 */
.tasks-completed-section {
  background: #FFF4EC;
  border: 1rpx solid rgba(255, 107, 0, 0.3);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.completed-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.completed-icon { font-size: 36rpx; }

.completed-text {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 600;
}
