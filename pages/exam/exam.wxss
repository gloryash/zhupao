/* pages/exam/exam.wxss */

/* 页面容器 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
  padding-bottom: 150rpx;
}

/* 考试标题 */
.exam-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.3);
}

.exam-title {
  display: block;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.exam-info {
  display: block;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
}

/* 题目列表 */
.question-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.question-item {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.question-header {
  display: flex;
  margin-bottom: 20rpx;
}

.question-number {
  color: #1890ff;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 10rpx;
}

.question-text {
  flex: 1;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 选项列表 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.option-item {
  width: 100%;
}

.option-content {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 15rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.option-content.selected {
  background-color: #e6f7ff;
  border-color: #1890ff;
}

.option-radio {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  margin-right: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-content.selected .option-radio {
  border-color: #1890ff;
}

.radio-inner {
  width: 24rpx;
  height: 24rpx;
  background-color: #1890ff;
  border-radius: 50%;
}

.option-label {
  color: #1890ff;
  font-size: 26rpx;
  font-weight: bold;
  margin-right: 10rpx;
}

.option-text {
  flex: 1;
  color: #333;
  font-size: 26rpx;
  line-height: 1.5;
}

/* 提交按钮区域 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #1890ff 0%, #0066cc 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(24, 144, 255, 0.3);
}

.submit-btn::after {
  border: none;
}

/* 考试结果 */
.result-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

.result-card {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.1);
  width: 100%;
}

.result-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.result-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.result-score {
  display: block;
  font-size: 60rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 15rpx;
}

.result-tip {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 100%;
  height: 100rpx;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
}

.secondary-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a52 100%);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.3);
}