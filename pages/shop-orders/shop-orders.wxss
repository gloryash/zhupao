/* pages/shop-orders/shop-orders.wxss */

/* 容器 */
.orders-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 订单卡片 */
.order-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-product {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.product-avatar {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.product-avatar.large {
  width: 120rpx;
  height: 120rpx;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.product-info {
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

.order-body {
  padding: 20rpx 24rpx;
}

.order-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.row-label {
  font-size: 26rpx;
  color: #999;
}

.row-value {
  font-size: 26rpx;
  color: #333;
}

.row-value.code {
  font-family: monospace;
  letter-spacing: 2rpx;
  color: #667eea;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.order-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
  border-radius: 50%;
  background: #f5f5f5;
}

.modal-content {
  padding: 30rpx;
}

.product-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.product-section .product-name {
  margin-top: 16rpx;
  font-size: 32rpx;
}

.product-section .product-desc {
  font-size: 24rpx;
  color: #999;
}

.code-section {
  text-align: center;
  margin-bottom: 30rpx;
}

.section-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.code-box {
  display: inline-block;
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.code-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 6rpx;
  font-family: monospace;
}

.code-hint {
  font-size: 24rpx;
  color: #999;
}

.info-section {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.modal-footer {
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.verify-btn,
.delete-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.verify-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.delete-btn {
  background: #f5f5f5;
  color: #ef4444;
}

.verify-btn::after,
.delete-btn::after {
  border: none;
}
