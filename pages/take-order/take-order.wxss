/* 页面容器 - 全屏布局 */
.map-page {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background-color: #f5f7fa;
}

/* 全屏地图 */
.fullscreen-map {
  width: 100%;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.fullscreen-map.hidden {
  opacity: 0;
}

/* 位置加载中 */
.location-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #E8F5E9 0%, #F1F8E9 100%);
  z-index: 5;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

.loading-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 15rpx;
}

.loading-hint {
  font-size: 24rpx;
  color: #999;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.8;
  }
}

/* 顶部标题栏 */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 40rpx 30rpx;
}

.title-bar {
  background-color: #ffffff;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 状态徽章 */
.status-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: #ffffff;
  border-radius: 50%;
}

.status-dot.breathing {
  animation: breathing 1.5s ease-in-out infinite;
}

@keyframes breathing {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(0.8);
  }
}

.status-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 预约广场入口 */
.appointment-entry {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(247, 147, 30, 0.3);
}

.entry-icon {
  font-size: 28rpx;
}

.entry-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

/* 底部信息面板 */
.bottom-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 30rpx;
}

/* 订单卡片 */
.order-card {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 0;
  box-shadow: 0 -4rpx 40rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #ffffff 100%);
  border-bottom: 1rpx solid #f0f2f5;
}

/* 头像容器 */
.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
}

.user-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #ffffff;
}

.avatar-ring {
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  right: -6rpx;
  bottom: -6rpx;
  border: 4rpx solid #667eea;
  border-radius: 50%;
  opacity: 0.3;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.user-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: #667eea;
  background-color: rgba(102, 126, 234, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 距离徽章 */
.distance-badge {
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: baseline;
  box-shadow: 0 6rpx 16rpx rgba(7, 193, 96, 0.3);
}

.distance-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.distance-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 6rpx;
}

/* 订单详情网格 */
.order-details {
  padding: 24rpx 32rpx;
}

.detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.detail-cell {
  background-color: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-icon {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
}

.detail-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.detail-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.location-text {
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 状态区域 */
.status-section {
  padding: 32rpx;
  border-top: 1rpx solid #f0f2f5;
}

/* 等待中 - 呼吸动画 */
.waiting {
  text-align: center;
  padding: 40rpx 32rpx;
}

.breathing-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.breathing-ring,
.pulse-icon {
  position: absolute;
  border-radius: 50%;
}

.breathing-ring {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.3) 0%, rgba(118, 75, 162, 0.3) 100%);
  animation: pulse-ring 2s ease-out infinite;
}

.breathing-ring.delay-1 {
  animation-delay: 0.3s;
  transform: scale(0.85);
}

.breathing-ring.delay-2 {
  animation-delay: 0.6s;
  transform: scale(0.7);
}

@keyframes pulse-ring {
  0% {
    transform: scale(1);
    opacity: 0.6;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

.pulse-icon {
  font-size: 64rpx;
  z-index: 1;
}

.status-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 24rpx;
  display: block;
}

/* 已接单 - 操作按钮 */
.accepted {
  background-color: #fffbeb;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.action-btn::after {
  border: none;
}

.phone-btn {
  background-color: #ffffff;
  color: #333;
  border: 2rpx solid #e5e7eb;
}

.nav-btn {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
}

/* 已到达 */
.arrived {
  background-color: #f0fdf4;
  text-align: center;
}

.arrived-info {
  margin-bottom: 24rpx;
}

.arrived-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #07c160;
  display: block;
  margin-bottom: 8rpx;
}

.arrived-hint {
  font-size: 26rpx;
  color: #666;
}

/* 陪跑中 */
.running {
  background-color: #f0f9ff;
}

.running-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value-large {
  font-size: 48rpx;
  font-weight: bold;
  color: #07c160;
  line-height: 1;
  margin-bottom: 6rpx;
}

.stat-unit {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 轨迹追踪指示器 */
.tracking-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background-color: #e8f5e9;
  border-radius: 30rpx;
}

.pulse-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: #07c160;
  border-radius: 50%;
  animation: pulse-dot 1.5s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% {
   transform: scale(1);
   opacity: 1;
 }
 50% {
   transform: scale(1.3);
   opacity: 0.7;
 }
}

.tracking-text {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 500;
}

.running-hint {
  font-size: 24rpx;
  color: #1890ff;
  text-align: center;
  margin-bottom: 16rpx;
}

/* 已完成 */
.completed {
  text-align: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0fdf4 100%);
}

.completed-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.completed-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #07c160;
  display: block;
  margin-bottom: 8rpx;
}

.completed-hint {
  font-size: 28rpx;
  color: #666;
}

/* 无订单卡片 */
.no-order-card {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 -4rpx 40rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

/* 搜索动画 */
.searching-animation {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 24rpx;
}

.search-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #667eea;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  opacity: 0.3;
}

.search-ring.delay-1 {
  width: 110rpx;
  height: 110rpx;
  animation-delay: 0.3s;
}

.search-ring.delay-2 {
  width: 140rpx;
  height: 140rpx;
  animation-delay: 0.6s;
}

.search-ring,
.search-ring.delay-1,
.search-ring.delay-2 {
  animation: search-pulse 2s ease-out infinite;
}

@keyframes search-pulse {
  0% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.4;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.5);
    opacity: 0;
  }
}

.search-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 48rpx;
}

.no-order-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.no-order-desc {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.no-order-hint {
  font-size: 24rpx;
  color: #ccc;
}

/* 主按钮样式 */
.primary-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 34rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.primary-btn::after {
  border: none;
}

.waiting .primary-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.running-btn {
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.end-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.btn-icon {
  font-size: 36rpx;
}

/* 评价弹窗 */
.rating-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rating-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.rating-content {
  position: relative;
  width: 90%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.rating-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.rating-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.rating-subtitle {
  font-size: 26rpx;
  color: #999;
}

.rating-section {
  margin-bottom: 32rpx;
}

.rating-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.star-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.star {
  padding: 10rpx;
}

.star-icon {
  font-size: 48rpx;
  color: #ddd;
  transition: all 0.2s;
}

.star-icon.active {
  color: #fbbf24;
  transform: scale(1.1);
}

.comment-input {
  width: 100%;
  height: 72rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.submit-rating-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.submit-rating-btn::after {
  border: none;
}
