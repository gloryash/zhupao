.stage-toast {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(var(--safe-bottom, 0px) + 118rpx);
  z-index: 18;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  border: 3rpx solid rgba(36, 51, 38, 0.84);
  background: linear-gradient(180deg, rgba(255, 248, 226, 0.96), rgba(224, 195, 129, 0.94));
  color: #243326;
  box-shadow: 0 8rpx 0 #8a6b3c, 0 18rpx 40rpx rgba(0, 0, 0, 0.25);
}

.stage-toast-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.stage-toast-title {
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.15;
}

.stage-toast-meta {
  font-size: 23rpx;
  font-weight: 900;
  color: #0f5a47;
}

.stage-toast-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.25;
  color: rgba(36, 51, 38, 0.74);
}

.stage-toast-track {
  height: 16rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(54, 58, 48, 0.22);
}

.stage-toast-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #ffb842, #74d765, #56cdb4);
}

.stage-switch {
  position: absolute;
  left: 26rpx;
  right: 26rpx;
  bottom: calc(var(--safe-bottom, 0px) + 22rpx);
  z-index: 18;
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.stage-switch-item {
  flex: 0 0 auto;
  min-height: 68rpx;
  padding: 10rpx 16rpx 10rpx 10rpx;
  border-radius: 999rpx;
  border: 3rpx solid rgba(33, 43, 35, 0.86);
  background: linear-gradient(180deg, #fff4d8, #d9bb78);
  color: #243326;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 6rpx 0 #82643a;
}

.stage-switch-item.is-current {
  background: linear-gradient(180deg, #ffce67, #ec8f35);
}

.stage-switch-item.is-locked {
  opacity: 0.48;
  filter: grayscale(1);
}

.stage-switch-dot {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #14784d;
  color: #fff7de;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 950;
}

.stage-switch-label {
  font-size: 22rpx;
  font-weight: 900;
}

.map-action {
  min-height: 72rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: #ffd36c;
  color: #1c1813;
  font-size: 26rpx;
  font-weight: 900;
}

.stage-sheet {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  background: rgba(4, 8, 7, 0.58);
}

.stage-sheet-panel {
  width: 100%;
  padding: 34rpx 28rpx calc(var(--safe-bottom, 0px) + 30rpx);
  border-radius: 34rpx 34rpx 0 0;
  background: #f4eddd;
  border-top: 3rpx solid rgba(255, 255, 255, 0.8);
  color: #1c1813;
}

.sheet-title {
  display: block;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1.2;
}

.sheet-sub {
  display: block;
  margin-top: 8rpx;
  color: #574f41;
  font-size: 24rpx;
  line-height: 1.42;
}

.return-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.return-stop {
  min-height: 166rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #fffdf7;
  border: 3rpx solid rgba(28, 24, 19, 0.12);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.return-stop.is-current {
  border-color: #0f5a47;
  box-shadow: 0 0 0 5rpx rgba(15, 90, 71, 0.12);
}

.return-mini-map {
  width: 82rpx;
  height: 54rpx;
  border-radius: 18rpx;
  background:
    radial-gradient(circle at 35% 50%, #6cdb62 0 34%, transparent 35%),
    radial-gradient(circle at 66% 42%, #58c6d8 0 22%, transparent 23%),
    #b88443;
  border: 3rpx solid rgba(28, 24, 19, 0.18);
}

.return-name {
  margin-top: 12rpx;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.2;
}

.return-meta {
  margin-top: 6rpx;
  color: #706858;
  font-size: 22rpx;
  line-height: 1.2;
}
