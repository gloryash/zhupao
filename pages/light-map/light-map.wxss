page {
  background: #17231f;
}

.light-page {
  min-height: 100vh;
  height: 100vh;
  padding: calc(var(--status-bar-height, 0px) + 16rpx) 22rpx calc(var(--safe-bottom, 0px) + 18rpx);
  position: relative;
  overflow: hidden;
  color: #fff7de;
  background:
    radial-gradient(circle at 24% 18%, rgba(255, 218, 117, 0.22), transparent 28%),
    radial-gradient(circle at 72% 74%, rgba(82, 176, 126, 0.2), transparent 30%),
    linear-gradient(145deg, #263126 0%, #1c2721 48%, #0f1715 100%);
}

.terrain-shell--island {
  background:
    radial-gradient(circle at 28% 20%, rgba(255, 215, 118, 0.28), transparent 30%),
    radial-gradient(circle at 68% 54%, rgba(85, 196, 128, 0.28), transparent 38%),
    linear-gradient(145deg, #2d3a27 0%, #1d362b 44%, #172120 100%);
}

.terrain-shell--forest {
  background:
    radial-gradient(circle at 34% 22%, rgba(190, 221, 145, 0.2), transparent 28%),
    linear-gradient(145deg, #15251b 0%, #203b2a 54%, #111815 100%);
}

.terrain-shell--oasis {
  background:
    radial-gradient(circle at 44% 28%, rgba(255, 215, 119, 0.24), transparent 30%),
    linear-gradient(145deg, #594624 0%, #254a35 52%, #151d18 100%);
}

.terrain-shell--night {
  background:
    radial-gradient(circle at 70% 18%, rgba(255, 225, 142, 0.22), transparent 24%),
    linear-gradient(145deg, #0c1722 0%, #183024 54%, #07100e 100%);
}

.terrain-shell--plaza {
  background:
    radial-gradient(circle at 58% 30%, rgba(251, 219, 120, 0.24), transparent 28%),
    linear-gradient(145deg, #193326 0%, #31533d 52%, #101816 100%);
}

.game-hud {
  position: relative;
  z-index: 20;
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.hud-left {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.round-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 247, 222, 0.82);
  background: linear-gradient(180deg, #ff9f2f, #db5d2b);
  color: #fff7de;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 950;
  box-shadow: 0 8rpx 0 #7f321d, 0 18rpx 32rpx rgba(0, 0, 0, 0.32);
}

.round-btn--home {
  flex: 0 0 auto;
  font-size: 24rpx;
  background: linear-gradient(180deg, #36b56b, #14784d);
  box-shadow: 0 8rpx 0 #0c4833, 0 18rpx 32rpx rgba(0, 0, 0, 0.3);
}

.hud-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.hud-kicker {
  font-size: 20rpx;
  line-height: 1.1;
  color: rgba(255, 247, 222, 0.72);
}

.hud-title {
  font-size: 38rpx;
  line-height: 1.1;
  font-weight: 950;
  color: #fff7de;
  letter-spacing: 0;
}

.hud-sub {
  margin-top: 4rpx;
  font-size: 21rpx;
  line-height: 1.1;
  color: rgba(255, 247, 222, 0.76);
}

.hud-stats {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.hud-stat {
  min-width: 88rpx;
  height: 72rpx;
  padding: 8rpx 10rpx;
  border-radius: 18rpx;
  border: 3rpx solid rgba(25, 34, 28, 0.9);
  background: linear-gradient(180deg, #fff7df, #e8c988);
  color: #243326;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  box-shadow: 0 7rpx 0 #8a6b3c, 0 12rpx 22rpx rgba(0, 0, 0, 0.22);
}

.hud-stat-value {
  font-size: 30rpx;
  line-height: 1;
  font-weight: 950;
}

.hud-stat-label {
  margin-top: 3rpx;
  font-size: 16rpx;
  line-height: 1;
  color: rgba(36, 51, 38, 0.72);
  font-weight: 850;
}

.state-block {
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 18rpx;
  color: #fff7de;
  text-align: center;
}

.state-block--overlay {
  position: relative;
  z-index: 22;
}

.state-title {
  font-size: 34rpx;
  font-weight: 900;
}

.state-text {
  max-width: 520rpx;
  color: rgba(255, 247, 222, 0.78);
  font-size: 26rpx;
  line-height: 1.5;
}

.spinner {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 247, 222, 0.28);
  border-top-color: #ffd36c;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.map-stage {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  overflow: hidden;
}

.hex-grid {
  position: absolute;
  inset: 0;
  background-size: 92rpx 80rpx, 92rpx 80rpx;
  background-position: 0 0, 46rpx 40rpx;
}

.hex-grid--dark {
  background-color: #a77a3d;
  background-image:
    radial-gradient(circle at 50% 0%, transparent 27rpx, rgba(84, 58, 25, 0.34) 28rpx, rgba(84, 58, 25, 0.34) 31rpx, transparent 32rpx),
    radial-gradient(circle at 50% 100%, transparent 27rpx, rgba(84, 58, 25, 0.34) 28rpx, rgba(84, 58, 25, 0.34) 31rpx, transparent 32rpx);
}

.hex-grid--light {
  background-color: transparent;
  background-image:
    radial-gradient(circle at 50% 0%, transparent 27rpx, rgba(90, 134, 58, 0.28) 28rpx, rgba(90, 134, 58, 0.28) 31rpx, transparent 32rpx),
    radial-gradient(circle at 50% 100%, transparent 27rpx, rgba(90, 134, 58, 0.28) 28rpx, rgba(90, 134, 58, 0.28) 31rpx, transparent 32rpx);
  opacity: 0.88;
}

.terrain-shadow {
  position: absolute;
  z-index: 2;
  width: 42vw;
  height: 72vh;
  top: 18vh;
  border-radius: 50%;
  background: rgba(41, 29, 15, 0.36);
  filter: blur(24rpx);
}

.terrain-shadow--left { left: -30vw; }
.terrain-shadow--right { right: -30vw; }

.terrain-island {
  position: absolute;
  left: 50%;
  top: 53%;
  width: 960rpx;
  height: 1020rpx;
  transform: translate(-50%, -50%) rotate(-7deg);
  z-index: 5;
  border-radius: 48% 52% 45% 55%;
  background:
    radial-gradient(circle at 32% 60%, #5fd660 0 19%, transparent 20%),
    radial-gradient(circle at 68% 40%, #67df6b 0 19%, transparent 20%),
    radial-gradient(circle at 52% 55%, #65dc63 0 42%, transparent 43%),
    radial-gradient(circle at 48% 50%, #38a848 0 57%, transparent 58%);
  box-shadow:
    0 26rpx 0 #2d7c35,
    0 58rpx 80rpx rgba(0, 0, 0, 0.24),
    inset 0 0 0 12rpx rgba(255, 255, 255, 0.06);
}

.ground-ring {
  position: absolute;
  border-radius: 50%;
  background: rgba(79, 185, 75, 0.34);
  border: 3rpx solid rgba(45, 124, 53, 0.25);
}

.ground-ring--outer {
  width: 690rpx;
  height: 520rpx;
  left: 120rpx;
  top: 234rpx;
}

.ground-ring--middle {
  width: 460rpx;
  height: 340rpx;
  left: 264rpx;
  top: 344rpx;
  background: rgba(143, 224, 91, 0.22);
}

.ground-ring--inner {
  width: 245rpx;
  height: 188rpx;
  left: 378rpx;
  top: 414rpx;
  background: rgba(255, 229, 132, 0.12);
}

.road-main {
  position: absolute;
  left: 132rpx;
  top: 470rpx;
  width: 695rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background:
    linear-gradient(90deg, #eec65a, #f6d873 44%, #e6b64d 100%);
  transform: rotate(2deg);
  box-shadow: 0 8rpx 0 #b98a31, 0 0 0 6rpx rgba(121, 84, 34, 0.18);
  z-index: 6;
}

.road-highlight {
  position: absolute;
  left: 40rpx;
  top: 22rpx;
  width: 620rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
}

.road-branch {
  position: absolute;
  height: 48rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #efc95f, #f7db77);
  box-shadow: 0 7rpx 0 #b98a31;
  z-index: 5;
}

.road-branch--top {
  width: 260rpx;
  left: 470rpx;
  top: 356rpx;
  transform: rotate(-36deg);
}

.road-branch--right {
  width: 170rpx;
  left: 644rpx;
  top: 438rpx;
  transform: rotate(30deg);
}

.road-branch--bottom {
  width: 205rpx;
  left: 292rpx;
  top: 558rpx;
  transform: rotate(32deg);
}

.route-node {
  position: absolute;
  z-index: 10;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 5rpx solid #fff6d6;
  background: linear-gradient(180deg, #ff8e37, #d94f2a);
  color: #fff7de;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 29rpx;
  font-weight: 950;
  box-shadow: 0 8rpx 0 #8e3420, 0 14rpx 26rpx rgba(0, 0, 0, 0.24);
  transform: rotate(7deg);
}

.route-node--start { left: 162rpx; top: 456rpx; }
.route-node--mid { left: 476rpx; top: 424rpx; }
.route-node--end { left: 738rpx; top: 402rpx; background: linear-gradient(180deg, #6f7b72, #3c4640); box-shadow: 0 8rpx 0 #252c27; }
.route-node--end.is-complete { background: linear-gradient(180deg, #ffcf58, #e87c2f); box-shadow: 0 8rpx 0 #9e5321; color: #2f2416; }

.landmark {
  position: absolute;
  z-index: 12;
  width: 132rpx;
  height: 132rpx;
  transform: translate(-50%, -50%) rotate(7deg);
}

.landmark-shadow {
  position: absolute;
  left: 22rpx;
  right: 20rpx;
  bottom: 8rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(32, 58, 35, 0.22);
}

.landmark-shape {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 112rpx;
  height: 112rpx;
  transform: translate(-50%, -50%);
}

.landmark.is-muted {
  opacity: 0.72;
}

.landmark.is-muted .landmark-shape {
  background-color: rgba(90, 98, 85, 0.18);
}

.landmark.is-lit {
  opacity: 1;
  animation: landmarkPop 520ms ease both;
}

@keyframes landmarkPop {
  from { transform: translate(-50%, -50%) rotate(7deg) scale(0.86); opacity: 0.74; }
  to { transform: translate(-50%, -50%) rotate(7deg) scale(1); opacity: 1; }
}

.tree-crown,
.tree-trunk,
.park-path,
.lake-shape,
.lake-shine,
.lake-bridge,
.shop-base,
.shop-roof,
.shop-window,
.shop-sign,
.building-roof,
.bridge-arch,
.bridge-road,
.windmill-tower,
.windmill-hub,
.windmill-blades,
.tower-body,
.tower-top,
.plaza-base,
.person-board,
.person-body,
.person-head,
.lamp-post,
.lamp-light {
  display: none;
}

