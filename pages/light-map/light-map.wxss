}

.stage-focus-label {
  position: absolute;
  z-index: 14;
  color: #fffaf0;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 950;
  transform: rotateZ(45deg) rotateX(-34deg) translateZ(78rpx);
  text-shadow:
    0 4rpx 0 rgba(54, 44, 25, 0.62),
    4rpx 0 0 rgba(54, 44, 25, 0.45),
    -4rpx 0 0 rgba(54, 44, 25, 0.45);
}

.stage-focus-label--one-two {
  left: 612rpx;
  top: 392rpx;
}

.stage-focus-label--one-three {
  left: 754rpx;
  top: 512rpx;
}

.stage-focus-label--one-four {
  left: 940rpx;
  top: 630rpx;
}

.island-hex-field {
  position: absolute;
  z-index: 4;
  left: 152rpx;
  top: 126rpx;
  width: 1180rpx;
  height: 850rpx;
}

.island-hex-tile {
  position: absolute;
  width: 186rpx;
  height: 88rpx;
  clip-path: polygon(25% 0, 75% 0, 100% 50%, 75% 100%, 25% 100%, 0 50%);
  background-size: 126rpx 60rpx;
  background-position: center;
  box-shadow:
    inset 0 -10rpx 0 rgba(42, 32, 22, 0.18),
    0 8rpx 0 rgba(59, 44, 29, 0.24);
}

.island-hex-tile.is-lit {
  background:
    radial-gradient(circle at 45% 23%, rgba(245, 255, 163, 0.42), transparent 32%),
    linear-gradient(180deg, #91e85d, #36b848);
  box-shadow:
    inset 0 -10rpx 0 rgba(32, 128, 48, 0.22),
    0 8rpx 0 rgba(37, 116, 45, 0.34),
    0 0 26rpx rgba(120, 239, 96, 0.26);
}

.island-hex-tile.is-locked {
  background: #735c3d;
  filter: saturate(0.82) brightness(0.86);
}

.island-lake-tile.is-lit {
  background:
    radial-gradient(circle at 35% 28%, rgba(255, 255, 255, 0.52), transparent 19%),
    linear-gradient(145deg, #5fe2ee, #13aed0 55%, #0a80bc);
