page {
  background: #c8a15b;
}

.light-page {
  min-height: 100vh;
  height: 100vh;
  padding: calc(var(--status-bar-height, 0px) + 16rpx) 22rpx calc(var(--safe-bottom, 0px) + 18rpx);
  position: relative;
  overflow: hidden;
  color: #fff9e9;
  background:
    radial-gradient(circle at 18% 18%, rgba(255, 232, 154, 0.42), transparent 24%),
    radial-gradient(circle at 78% 70%, rgba(122, 190, 112, 0.18), transparent 28%),
    linear-gradient(145deg, #e7c981 0%, #c8a15b 48%, #9d7442 100%);
}

.terrain-shell--island {
  background:
    radial-gradient(circle at 28% 20%, rgba(255, 231, 143, 0.5), transparent 30%),
    radial-gradient(circle at 68% 54%, rgba(93, 195, 126, 0.28), transparent 38%),
    linear-gradient(145deg, #edd18a 0%, #c8a15b 46%, #8e6840 100%);
}

.terrain-shell--oasis {
  background:
    radial-gradient(circle at 44% 28%, rgba(255, 226, 134, 0.42), transparent 30%),
    radial-gradient(circle at 76% 66%, rgba(58, 177, 148, 0.2), transparent 26%),
    linear-gradient(145deg, #d9b364 0%, #b68a46 52%, #826343 100%);
}

.terrain-shell--risk {
  background:
    radial-gradient(circle at 70% 18%, rgba(255, 225, 142, 0.34), transparent 24%),
    linear-gradient(145deg, #bc9b63 0%, #7d704e 54%, #4e5146 100%);
}

.terrain-shell--peril {
  background:
    radial-gradient(circle at 58% 30%, rgba(255, 220, 130, 0.36), transparent 28%),
    linear-gradient(145deg, #b99458 0%, #6f684f 52%, #41433c 100%);
}

.terrain-shell--dawn {
  background:
    radial-gradient(circle at 58% 30%, rgba(255, 236, 159, 0.46), transparent 28%),
    radial-gradient(circle at 42% 74%, rgba(99, 198, 142, 0.24), transparent 32%),
    linear-gradient(145deg, #f0c972 0%, #b99253 52%, #5f6a54 100%);
}

.game-hud {
  position: relative;
  z-index: 20;
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 8rpx 0;
}

.hud-left {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.round-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 247, 222, 0.82);
  background: linear-gradient(180deg, #ff9f2f, #db5d2b);
  color: #fff7de;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 950;
  box-shadow: 0 8rpx 0 #7f321d, 0 18rpx 32rpx rgba(0, 0, 0, 0.32);
}

.round-btn--home {
  flex: 0 0 auto;
  font-size: 24rpx;
  background: linear-gradient(180deg, #36b56b, #14784d);
  box-shadow: 0 8rpx 0 #0c4833, 0 18rpx 32rpx rgba(0, 0, 0, 0.3);
}

.hud-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.hud-kicker {
  font-size: 20rpx;
  line-height: 1.1;
  color: rgba(255, 249, 233, 0.82);
}

.hud-title {
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 950;
  color: #fff7de;
  letter-spacing: 0;
}

.hud-sub {
  margin-top: 4rpx;
  font-size: 21rpx;
  line-height: 1.1;
  color: rgba(255, 249, 233, 0.82);
}

.hud-stats {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.star-meter {
  min-width: 88rpx;
  height: 72rpx;
  padding: 8rpx 12rpx;
  border-radius: 18rpx;
  border: 3rpx solid rgba(25, 34, 28, 0.9);
  background: linear-gradient(180deg, #3cb9ee, #1875c4);
  color: #fff7de;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 7rpx 0 #0c477a, 0 12rpx 22rpx rgba(0, 0, 0, 0.22);
}

.star-meter-icon {
  color: #ffd45f;
  font-size: 31rpx;
  line-height: 1;
  text-shadow: 0 3rpx 0 rgba(78, 47, 13, 0.28);
}

.star-meter-value {
  font-size: 30rpx;
  line-height: 1;
  font-weight: 950;
}

.hud-stat {
  min-width: 88rpx;
  height: 72rpx;
  padding: 8rpx 10rpx;
  border-radius: 18rpx;
  border: 3rpx solid rgba(25, 34, 28, 0.9);
  background: linear-gradient(180deg, #fff7df, #e8c988);
  color: #243326;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  box-shadow: 0 7rpx 0 #8a6b3c, 0 12rpx 22rpx rgba(0, 0, 0, 0.22);
}

.hud-stat-value {
  font-size: 30rpx;
  line-height: 1;
  font-weight: 950;
}

.hud-stat-label {
  margin-top: 3rpx;
  font-size: 16rpx;
  line-height: 1;
  color: rgba(36, 51, 38, 0.72);
  font-weight: 850;
}

.state-block {
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 18rpx;
  color: #fff7de;
  text-align: center;
}

.state-block--overlay {
  position: relative;
  z-index: 22;
}

.state-title {
  font-size: 34rpx;
  font-weight: 900;
}

.state-text {
  max-width: 520rpx;
  color: rgba(255, 247, 222, 0.78);
  font-size: 26rpx;
  line-height: 1.5;
}

.spinner {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 247, 222, 0.28);
  border-top-color: #ffd36c;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.map-stage {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  overflow: hidden;
}

.hex-grid {
  position: absolute;
  inset: 0;
  background-size: 92rpx 80rpx, 92rpx 80rpx;
  background-position: 0 0, 46rpx 40rpx;
}

.hex-grid--dark {
  background-color: #c8a15b;
  background-image:
    radial-gradient(circle at 50% 0%, transparent 27rpx, rgba(82, 64, 44, 0.38) 28rpx, rgba(82, 64, 44, 0.38) 31rpx, transparent 32rpx),
    radial-gradient(circle at 50% 100%, transparent 27rpx, rgba(82, 64, 44, 0.38) 28rpx, rgba(82, 64, 44, 0.38) 31rpx, transparent 32rpx);
}

.hex-grid--light {
  background-color: transparent;
  background-image:
    radial-gradient(circle at 50% 0%, transparent 27rpx, rgba(90, 134, 58, 0.28) 28rpx, rgba(90, 134, 58, 0.28) 31rpx, transparent 32rpx),
    radial-gradient(circle at 50% 100%, transparent 27rpx, rgba(90, 134, 58, 0.28) 28rpx, rgba(90, 134, 58, 0.28) 31rpx, transparent 32rpx);
  opacity: 0.72;
}

.terrain-shadow {
  position: absolute;
  z-index: 2;
  width: 42vw;
  height: 72vh;
  top: 18vh;
  border-radius: 50%;
  background: rgba(64, 48, 33, 0.24);
  filter: blur(24rpx);
}

.terrain-shadow--left { left: -30vw; }
.terrain-shadow--right { right: -30vw; }

.diorama-camera {
  position: absolute;
  left: 50%;
  top: 56%;
  width: 960rpx;
  height: 1020rpx;
  z-index: 5;
  transform: translate(-50%, -50%) rotateX(58deg) rotateZ(-7deg);
  transform-style: preserve-3d;
  perspective: 1800rpx;
}

.newbie-island-demo {
  position: absolute;
  inset: 0;
  z-index: 6;
  overflow: hidden;
  background: #d59a3a;
}

.island-blue-saw-edge {
  position: absolute;
  z-index: 12;
  left: -42rpx;
  right: -42rpx;
  height: 56rpx;
  pointer-events: none;
  background:
    linear-gradient(135deg, #13a8df 25%, transparent 25%) 0 0 / 42rpx 42rpx repeat-x,
    linear-gradient(225deg, #13a8df 25%, transparent 25%) 21rpx 0 / 42rpx 42rpx repeat-x,
    linear-gradient(180deg, #1fb6ef, #0a83c8);
  box-shadow: 0 6rpx 0 rgba(5, 92, 150, 0.42);
}

.island-blue-saw-edge--top {
  top: calc(var(--status-bar-height, 0px) + 84rpx);
  transform: rotate(180deg);
}

.island-blue-saw-edge--bottom {
  bottom: calc(var(--safe-bottom, 0px) + 8rpx);
}

.island-team-panel {
  position: absolute;
  z-index: 23;
  top: calc(var(--status-bar-height, 0px) + 104rpx);
  right: 18rpx;
  width: 244rpx;
  min-height: 104rpx;
  padding: 16rpx 18rpx 14rpx;
  box-sizing: border-box;
  border: 5rpx solid rgba(155, 223, 255, 0.88);
  background: linear-gradient(180deg, #168be0, #075aaf);
  color: #fff7de;
  box-shadow: 0 9rpx 0 #06447f, 0 18rpx 36rpx rgba(15, 52, 85, 0.34);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.island-team-pad {
  position: relative;
  width: 48rpx;
  height: 33rpx;
  border-radius: 16rpx 16rpx 10rpx 10rpx;
  background: #f8fcff;
  border: 4rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 7rpx 0 rgba(3, 47, 84, 0.28);
}

.island-team-pad::before,
.island-team-pad::after {
  content: "";
  position: absolute;
  bottom: -10rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: inherit;
  border: inherit;
}

.island-team-pad::before { left: 2rpx; }
.island-team-pad::after { right: 2rpx; }

.island-team-pad--red {
  background: #df4945;
}

.island-team-plus {
  width: 38rpx;
  height: 38rpx;
  border-radius: 8rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.54);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 950;
  color: rgba(255, 255, 255, 0.76);
}

.island-team-title {
  position: absolute;
  left: 18rpx;
  bottom: -36rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(8, 78, 136, 0.9);
  font-size: 20rpx;
  line-height: 1.15;
  font-weight: 900;
}

.island-map-frame {
  position: absolute;
  z-index: 7;
  left: -120rpx;
  right: -120rpx;
  top: calc(var(--status-bar-height, 0px) + 74rpx);
  bottom: calc(var(--safe-bottom, 0px) - 32rpx);
  overflow: hidden;
  perspective: 5200rpx;
}

.island-cut-edge {
  position: absolute;
  z-index: 20;
  left: -40rpx;
  right: -40rpx;
  height: 54rpx;
  background:
    linear-gradient(135deg, #0d9ed8 25%, transparent 25%) 0 0 / 42rpx 42rpx repeat-x,
    linear-gradient(225deg, #0d9ed8 25%, transparent 25%) 21rpx 0 / 42rpx 42rpx repeat-x;
  opacity: 0.92;
}

.island-cut-edge--top {
  top: 0;
  transform: rotate(180deg);
}

.island-cut-edge--bottom {
  bottom: 0;
}

.newbie-island-camera {
  top: 58%;
  width: 1480rpx;
  height: 1120rpx;
  transform: translate(-50%, -50%) rotateX(34deg) rotateZ(-45deg);
  transform-origin: 50% 52%;
  perspective: 5200rpx;
}

.newbie-island-board {
  position: absolute;
  inset: 0;
  border-radius: 30rpx;
  overflow: hidden;
  background: #d59a3a;
  background-image:
    radial-gradient(circle at 50% 0%, transparent 36rpx, rgba(132, 91, 31, 0.28) 37rpx, rgba(132, 91, 31, 0.28) 40rpx, transparent 41rpx),
    radial-gradient(circle at 50% 100%, transparent 36rpx, rgba(132, 91, 31, 0.24) 37rpx, rgba(132, 91, 31, 0.24) 40rpx, transparent 41rpx);
  background-size: 126rpx 60rpx, 126rpx 60rpx;
  background-position: 0 0, 63rpx 30rpx;
  box-shadow:
    0 18rpx 0 #9d6f2c,
    0 36rpx 52rpx rgba(92, 58, 21, 0.2),
    inset 0 0 0 8rpx rgba(255, 231, 161, 0.16);
}

.island-lake-mass {
  position: absolute;
  z-index: 3;
  left: 300rpx;
  top: 160rpx;
  width: 620rpx;
  height: 430rpx;
  border-radius: 44% 56% 48% 52%;
  background:
    radial-gradient(circle at 26% 30%, rgba(255, 255, 255, 0.34) 0 5%, transparent 6%),
    radial-gradient(circle at 76% 68%, rgba(0, 126, 164, 0.24) 0 13%, transparent 14%),
    linear-gradient(145deg, #4ee3e7 0%, #15b8d2 54%, #097fba 100%);
  border: 8rpx solid rgba(7, 105, 145, 0.5);
  box-shadow:
    inset 0 -18rpx 0 rgba(5, 91, 139, 0.14),
    0 10rpx 0 rgba(7, 92, 120, 0.16);
}

.lake-wave {
  position: absolute;
  height: 11rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
}

.lake-wave--a {
  left: 115rpx;
  top: 116rpx;
  width: 148rpx;
  transform: rotate(-10deg);
}

.lake-wave--b {
  right: 142rpx;
  top: 260rpx;
  width: 116rpx;
  transform: rotate(-13deg);
}

.lake-wave--c {
  left: 300rpx;
  top: 332rpx;
  width: 74rpx;
  transform: rotate(-9deg);
}

.lake-rock {
  position: absolute;
  border-radius: 45% 55% 42% 48%;
  background: linear-gradient(180deg, #d4bc89, #805d36);
  box-shadow: 0 6rpx 0 rgba(72, 49, 29, 0.22);
}

.lake-rock--a {
  left: 22rpx;
  top: 254rpx;
  width: 58rpx;
  height: 34rpx;
}

.lake-rock--b {
  right: 58rpx;
  top: 202rpx;
  width: 46rpx;
  height: 30rpx;
}

.lake-buoy {
  position: absolute;
  left: 248rpx;
  top: 284rpx;
  width: 28rpx;
  height: 38rpx;
  border-radius: 50% 50% 44% 44%;
  background: linear-gradient(180deg, #fff6dd 0 34%, #e23e30 34% 70%, #fff6dd 70%);
  border: 4rpx solid rgba(117, 49, 30, 0.72);
  transform: rotateZ(45deg) rotateX(-34deg) translateZ(32rpx);
  box-shadow: 0 8rpx 0 rgba(18, 78, 103, 0.26);
}

.island-grass-mass {
  position: absolute;
  z-index: 4;
  background:
    radial-gradient(circle at 38% 18%, rgba(226, 255, 116, 0.42), transparent 23%),
    linear-gradient(145deg, #a7ee54 0%, #62cf42 50%, #2eab43 100%);
  box-shadow:
    inset 0 -16rpx 0 rgba(28, 118, 44, 0.14),
    0 10rpx 0 rgba(58, 113, 35, 0.14);
}

.island-grass-mass--north {
  left: 455rpx;
  top: 74rpx;
  width: 500rpx;
  height: 230rpx;
  border-radius: 46% 54% 42% 58%;
}

.island-grass-mass--south {
  left: 560rpx;
  top: 520rpx;
  width: 620rpx;
  height: 320rpx;
  border-radius: 48% 52% 46% 54%;
}

.pine-grove,
.scene-pine,
.wood-fence,
.low-hill,
.island-building-cluster,
.roadside-flag,
.red-kiosk {
  position: absolute;
  transform: rotateZ(45deg) rotateX(-34deg) translateZ(56rpx);
  transform-style: preserve-3d;
}

.pine-grove--north {
  left: 150rpx;
  top: 46rpx;
  width: 190rpx;
  height: 120rpx;
}

.pine-grove--south {
  left: 358rpx;
  top: 94rpx;
  width: 230rpx;
  height: 150rpx;
}

.scene-pine {
  width: 42rpx;
  height: 62rpx;
  border-radius: 18rpx 18rpx 10rpx 10rpx;
  background: linear-gradient(180deg, #36c95d 0 35%, #1f9a4b 35% 68%, #14723d 68%);
  border: 3rpx solid rgba(45, 81, 39, 0.32);
  clip-path: polygon(50% 0, 86% 34%, 70% 34%, 96% 65%, 73% 65%, 84% 100%, 16% 100%, 27% 65%, 4% 65%, 30% 34%, 14% 34%);
  box-shadow: inset -5rpx -6rpx 0 rgba(0, 0, 0, 0.08);
}

.scene-pine--a { left: 0; top: 44rpx; }
.scene-pine--b { left: 42rpx; top: 12rpx; transform: scale(1.08); }
.scene-pine--c { left: 86rpx; top: 44rpx; transform: scale(0.86); }
.scene-pine--d { left: 128rpx; top: 26rpx; transform: scale(0.78); }
.scene-pine--e { left: 176rpx; top: 62rpx; transform: scale(0.84); }

.wood-fence {
  left: 254rpx;
  top: 138rpx;
  width: 112rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: repeating-linear-gradient(90deg, #865f36 0 18rpx, #e5bd6b 18rpx 34rpx);
  box-shadow: 0 5rpx 0 rgba(86, 58, 31, 0.26);
}

.low-hill {
  right: -6rpx;
  bottom: -10rpx;
  width: 185rpx;
  height: 86rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #a46c39, #765130);
  box-shadow: inset 0 14rpx 0 rgba(255, 215, 129, 0.12);
}

.island-building-cluster {
  z-index: 13;
  left: 980rpx;
  top: 660rpx;
