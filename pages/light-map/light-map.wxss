  height: 22rpx;
  border-radius: 5rpx;
  background: #7bd4e2;
  border: 3rpx solid #8c5b31;
}

.shop-sign {
  position: absolute;
  left: 72rpx;
  top: 24rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ffd15d;
  border: 3rpx solid #8c5b31;
}

.landmark--bridge .bridge-arch,
.landmark--bridge .bridge-road {
  display: block;
}

.bridge-arch {
  position: absolute;
  left: 14rpx;
  top: 46rpx;
  width: 92rpx;
  height: 42rpx;
  border-radius: 46rpx 46rpx 8rpx 8rpx;
  background: #caa05a;
  box-shadow: 0 8rpx 0 #8f6b34;
}

.bridge-road {
  position: absolute;
  left: 10rpx;
  top: 58rpx;
  width: 100rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #f0c667;
  border: 3rpx solid #8f6b34;
}

.landmark--windmill .windmill-tower,
.landmark--windmill .windmill-hub,
.landmark--windmill .windmill-blades {
  display: block;
}

.windmill-tower {
  position: absolute;
  left: 45rpx;
  top: 46rpx;
  width: 32rpx;
  height: 62rpx;
  border-radius: 8rpx 8rpx 14rpx 14rpx;
  background: #fff1c8;
  border: 4rpx solid #7d5632;
}

.windmill-hub {
  position: absolute;
  left: 52rpx;
  top: 30rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #f36c43;
  border: 3rpx solid #7d5632;
  z-index: 2;
}

.windmill-blades {
  position: absolute;
  left: 21rpx;
  top: 1rpx;
  width: 82rpx;
  height: 82rpx;
  border-radius: 50%;
  background:
    linear-gradient(0deg, transparent 42%, #fff4dc 42% 58%, transparent 58%),
    linear-gradient(90deg, transparent 42%, #fff4dc 42% 58%, transparent 58%);
  transform: rotate(28deg);
}

.landmark--tower .tower-body,
.landmark--tower .tower-top,
.landmark--tower .building-roof {
  display: block;
}

.tower-body {
  position: absolute;
  left: 42rpx;
  top: 34rpx;
  width: 38rpx;
  height: 74rpx;
  border-radius: 10rpx;
  background: #ffe0a0;
  border: 4rpx solid #765331;
  box-shadow: 0 8rpx 0 #765331;
}

.tower-top {
  position: absolute;
  left: 32rpx;
  top: 15rpx;
  width: 60rpx;
  height: 28rpx;
  border-radius: 14rpx;
  background: #ff8d38;
  border: 4rpx solid #765331;
}

.landmark--plaza .plaza-base {
  display: block;
}

.plaza-base {
  position: absolute;
  left: 18rpx;
  top: 42rpx;
  width: 84rpx;
  height: 62rpx;
  border-radius: 16rpx;
  background:
    linear-gradient(45deg, #d6b270 25%, transparent 25% 50%, #d6b270 50% 75%, transparent 75%),
    #f4d489;
  background-size: 22rpx 22rpx;
  border: 4rpx solid #8c683c;
  box-shadow: 0 8rpx 0 #8c683c;
}

.landmark--skater .person-board,
.landmark--skater .person-body,
.landmark--skater .person-head,
.landmark--runner .person-body,
.landmark--runner .person-head,
.landmark--kids .person-body,
.landmark--kids .person-head {
  display: block;
}

.person-board {
  position: absolute;
  left: 28rpx;
  top: 86rpx;
  width: 64rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #3757bd;
  transform: rotate(-9deg);
  box-shadow: 0 5rpx 0 #1f3275;
}

.person-body {
  position: absolute;
  left: 49rpx;
  top: 48rpx;
  width: 26rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background: #ff7f46;
  border: 3rpx solid #74351f;
}

.person-head {
  position: absolute;
  left: 48rpx;
  top: 23rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #ffd09f;
  border: 3rpx solid #74351f;
}

.landmark--lamp .lamp-post,
.landmark--lamp .lamp-light {
  display: block;
}

.lamp-post {
  position: absolute;
  left: 56rpx;
  top: 42rpx;
  width: 10rpx;
  height: 68rpx;
  border-radius: 999rpx;
  background: #5f4b34;
}

.lamp-light {
  position: absolute;
  left: 41rpx;
  top: 21rpx;
  width: 40rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #ffdf72;
  box-shadow: 0 0 32rpx rgba(255, 218, 102, 0.78);
}

.fog-edge {
  position: absolute;
  z-index: 16;
  pointer-events: none;
}

.fog-edge--top {
  left: -40rpx;
  right: -40rpx;
  top: -40rpx;
  height: 230rpx;
  background: linear-gradient(180deg, rgba(58, 42, 21, 0.76), transparent);
}

.fog-edge--bottom {
  left: -40rpx;
  right: -40rpx;
  bottom: -48rpx;
  height: 250rpx;
  background: linear-gradient(0deg, rgba(52, 38, 21, 0.78), transparent);
}

.fog-edge--left {
  left: -46rpx;
  top: -30rpx;
  bottom: -30rpx;
  width: 250rpx;
  background: linear-gradient(90deg, rgba(50, 38, 22, 0.78), transparent);
}

.fog-edge--right {
  right: -46rpx;
  top: -30rpx;
  bottom: -30rpx;
  width: 250rpx;
  background: linear-gradient(270deg, rgba(50, 38, 22, 0.78), transparent);
}

.map-action {
  min-height: 72rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: #ffd36c;
  color: #1c1813;
  font-size: 26rpx;
  font-weight: 900;
}

.node-progress-popover {
  position: absolute;
  inset: 0;
  z-index: 24;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 28rpx calc(var(--safe-bottom, 0px) + 34rpx);
  background: linear-gradient(180deg, transparent 0 42%, rgba(39, 31, 23, 0.46));
}

.node-progress-card {
  width: 100%;
  padding: 22rpx 22rpx 20rpx;
  border-radius: 22rpx;
  border: 4rpx solid rgba(44, 37, 27, 0.9);
  background: linear-gradient(180deg, #fff7dc, #e9c278);
  color: #2b271f;
  box-shadow: 0 10rpx 0 #8b6734, 0 22rpx 44rpx rgba(58, 38, 20, 0.3);
}

.node-progress-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.node-progress-kicker {
  display: block;
  font-size: 20rpx;
  line-height: 1.15;
  font-weight: 850;
  color: #476043;
}

.node-progress-title {
  display: block;
  margin-top: 5rpx;
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 950;
}

.node-progress-close {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #2e3b2d;
  color: #fff7de;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 950;
}

.node-progress-stars {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.node-progress-star {
  font-size: 34rpx;
  line-height: 1;
  color: rgba(79, 74, 63, 0.22);
}

.node-progress-star.is-filled {
  color: #ffc933;
  text-shadow: 0 3rpx 0 rgba(121, 79, 25, 0.24);
}

.node-progress-light {
  margin-left: 10rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #2076b9;
  color: #fff7de;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 950;
}

.node-progress-text,
.node-progress-voice {
  display: block;
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.35;
  color: #473f30;
}

.node-progress-voice {
  padding-top: 12rpx;
  border-top: 2rpx solid rgba(67, 55, 36, 0.14);
  color: #276245;
}

.stage-sheet {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  background: rgba(4, 8, 7, 0.58);
}

.stage-sheet-panel {
  width: 100%;
  height: 82vh;
  box-sizing: border-box;
  padding: 34rpx 28rpx calc(var(--safe-bottom, 0px) + 30rpx);
  border-radius: 34rpx 34rpx 0 0;
  background: #f6ead3;
  border-top: 3rpx solid rgba(255, 255, 255, 0.8);
  color: #1c1813;
  box-shadow: 0 -10rpx 50rpx rgba(42, 29, 16, 0.28);
}

.sheet-title {
  display: block;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1.2;
}

.sheet-sub {
  display: block;
  margin-top: 8rpx;
  color: #574f41;
  font-size: 24rpx;
  line-height: 1.42;
}

.room-tabs {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.room-tab {
  min-height: 58rpx;
  border-radius: 999rpx;
  background: #e3d1b2;
  color: #534634;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.room-tab.is-active {
  background: linear-gradient(180deg, #43bc6a, #1d864d);
  color: #fff7de;
  box-shadow: 0 6rpx 0 #115733;
}

.return-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.return-stop {
  min-height: 166rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fffdf7, #ead6ad);
  border: 3rpx solid rgba(28, 24, 19, 0.14);
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-shadow: 0 7rpx 0 rgba(124, 98, 58, 0.36);
}

.return-stop.is-current {
  border-color: #0f5a47;
  box-shadow: 0 0 0 5rpx rgba(15, 90, 71, 0.12);
}

.return-stop.is-locked {
  opacity: 0.56;
  filter: grayscale(0.65);
}

.return-mini-map {
  width: 82rpx;
  height: 54rpx;
  border-radius: 18rpx;
  background:
    radial-gradient(circle at 35% 50%, #6cdb62 0 34%, transparent 35%),
    radial-gradient(circle at 66% 42%, #58c6d8 0 22%, transparent 23%),
    #b88443;
  border: 3rpx solid rgba(28, 24, 19, 0.18);
}

.return-name {
  margin-top: 12rpx;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.2;
}

.return-meta {
  margin-top: 6rpx;
  color: #706858;
  font-size: 22rpx;
  line-height: 1.2;
}

.room-section {
  margin-top: 24rpx;
}

.room-section-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 950;
  color: #1c1813;
}

.run-record {
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #fffdf7;
  border: 2rpx solid rgba(28, 24, 19, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.run-record-title {
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #1c1813;
}

.run-record-meta {
  font-size: 22rpx;
  line-height: 1.2;
  color: #276245;
  font-weight: 850;
}

.team-row {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.team-slot {
  min-height: 134rpx;
  padding: 12rpx 8rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fffdf7, #e7d2a9);
  border: 2rpx solid rgba(28, 24, 19, 0.1);
  display: flex;
  align-items: center;
  flex-direction: column;
}

.team-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #3cb9ee, #1875c4);
  color: #fff7de;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 950;
}

.team-name {
  margin-top: 8rpx;
  max-width: 100%;
  font-size: 20rpx;
  line-height: 1.1;
  color: #1c1813;
  font-weight: 900;
  text-align: center;
}

.team-role {
  margin-top: 5rpx;
  font-size: 18rpx;
  line-height: 1;
  color: #706858;
}
