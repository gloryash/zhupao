/* 快速登录页面 - 渐变活力橙色主题 */
.quick-login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5E6 0%, #FFFFFF 100%);
  padding: 0 30rpx;
  padding-bottom: 60rpx;
}

/* 登录表单 */
.login-form {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.logo-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B00;
  margin-bottom: 8rpx;
  background: linear-gradient(135deg, #FF8C00 0%, #FF4500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.logo-subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 表单区域 */
.form-section {
  width: 100%;
  max-width: 600rpx;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(255, 140, 0, 0.1);
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 微信一键登录按钮 */
.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF8C00 0%, #FF4500 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 0, 0.3);
}

.wechat-login-btn::after {
  border: none;
}

.wechat-icon {
  font-size: 40rpx;
}

.wechat-text {
  font-size: 32rpx;
}

/* 分隔线 */
.divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 40rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #FFD699 50%, transparent 100%);
}

.divider-text {
  font-size: 24rpx;
  color: #999;
}

/* 手机号登录区域 */
.phone-login-section {
  margin-top: 20rpx;
}

.phone-login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 0, 0.3);
}

.phone-login-btn::after {
  border: none;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: bold;
}

.input-row {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  border: 1rpx solid #EEE;
}

.phone-input {
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
  color: #333;
}

.verify-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.code-input {
  flex: 1;
  height: 88rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #333;
  border: 1rpx solid #EEE;
}

.code-btn {
  width: 180rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%);
  border-radius: 12rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 0, 0.2);
}

.code-btn::after {
  border: none;
}

.code-btn.disabled {
  background: #EEE;
  color: #999;
  box-shadow: none;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 0, 0.3);
}

.login-btn::after {
  border: none;
}

/* 注册入口 */
.register-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 30rpx;
}

.register-text {
  font-size: 26rpx;
  color: #999;
}

.register-link {
  font-size: 26rpx;
  color: #FF6B00;
  font-weight: bold;
}

/* 功能说明 */
.feature-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 60rpx;
  width: 100%;
  max-width: 600rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 0, 0.08);
}

.feature-icon {
  font-size: 40rpx;
}

.feature-text {
  font-size: 28rpx;
  color: #666;
}

/* ===================== 已登录状态 ===================== */

/* 个人二维码区域 */
.personal-qr {
  padding-top: 40rpx;
}

/* 用户信息卡片 */
.header-card {
  background: linear-gradient(135deg, #FF8C00 0%, #FF4500 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(255, 140, 0, 0.3);
}

.user-greeting {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.user-detail {
  flex: 1;
}

.role-tags {
  display: flex;
  gap: 10rpx;
  margin-top: 8rpx;
}

.role-tag {
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #fff;
}

.role-tag.disabled {
  background: rgba(255, 255, 255, 0.3);
}

.logout-btn {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #fff;
}

/* 二维码区域 */
.qr-section {
  width: 100%;
}

.qr-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(255, 140, 0, 0.1);
}

.qr-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.qr-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.qr-hint {
  font-size: 24rpx;
  color: #999;
}

/* 二维码画布容器 */
.qr-canvas-container {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto;
  position: relative;
  background: #FFF5E6;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #FFD699;
}

.qr-canvas {
  width: 400rpx;
  height: 400rpx;
}

.qr-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* 无障碍定位标记 */
.accessibility-marks {
  position: absolute;
  top: 40rpx;
  left: 30rpx;
  right: 30rpx;
  bottom: 180rpx;
  pointer-events: none;
}

.mark {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  background: #FFB347;
  border-radius: 4rpx;
}

.mark.top-left {
  top: 0;
  left: 0;
}

.mark.top-right {
  top: 0;
  right: 0;
}

.mark.bottom-left {
  bottom: 0;
  left: 0;
}

.mark.bottom-right {
  bottom: 0;
  right: 0;
}

/* 缺口设计 */
.notch-design {
  display: flex;
  justify-content: space-between;
  padding: 0 20rpx;
  margin-top: 20rpx;
}

.notch {
  width: 40rpx;
  height: 8rpx;
  background: #FFB347;
  border-radius: 4rpx;
}

/* 登录码文字 */
.token-display {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx;
  background: #FFF5E6;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.token-label {
  font-size: 24rpx;
  color: #999;
}

.token-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF6B00;
  font-family: monospace;
}

/* 操作按钮 */
.qr-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  background: #F8F8F8;
  border: none;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 26rpx;
  color: #666;
}

.action-btn.primary .btn-text {
  color: #fff;
}

/* 使用说明 */
.usage-guide {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 0, 0.08);
}

.guide-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.guide-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.guide-num {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%);
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.guide-text {
  font-size: 26rpx;
  color: #666;
}

/* 紧急提醒 */
.emergency-alert {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid #FFB74D;
  margin-top: 30rpx;
}

.alert-icon {
  font-size: 48rpx;
}

.alert-content {
  flex: 1;
}

.alert-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #E65100;
  display: block;
}

.alert-desc {
  font-size: 22rpx;
  color: #F57C00;
}

.alert-btn {
  background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  border: none;
}

.alert-btn::after {
  border: none;
}

/* 紧急联系人弹窗 */
.emergency-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  width: 80%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20rpx 60rpx rgba(255, 140, 0, 0.2);
}

.modal-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF8C00 0%, #FF4500 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 0, 0.3);
}

.modal-btn::after {
  border: none;
}

.modal-skip {
  font-size: 26rpx;
  color: #999;
  padding: 10rpx;
}
