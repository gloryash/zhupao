<view class="quick-login-container">
  <!-- 未登录状态：登录表单 -->
  <view class="login-form" wx:if="{{!isLoggedIn}}">
    <!-- Logo区域 -->
    <view class="logo-section">
      <text class="logo-icon">🏃</text>
      <text class="logo-title">助盲跑</text>
      <text class="logo-subtitle">视障人士跑步助手</text>
    </view>

    <!-- 登录选项 -->
    <view class="form-section">
      <view class="form-card">
        <view class="form-title">快捷登录</view>

        <!-- 微信一键登录 -->
        <button class="wechat-login-btn" bindtap="handleWechatLogin">
          <text class="wechat-icon">📱</text>
          <text class="wechat-text">微信一键登录</text>
        </button>

        <!-- 分隔线 -->
        <view class="divider">
          <view class="divider-line"></view>
          <text class="divider-text">或</text>
          <view class="divider-line"></view>
        </view>

        <!-- 手机验证码登录 -->
        <view class="phone-login-section">
          <view class="input-group">
            <view class="input-label">手机号</view>
            <view class="input-row">
              <input class="phone-input" type="number" placeholder="请输入手机号" value="{{loginPhone}}" bindinput="onPhoneInput" maxlength="11" />
            </view>
          </view>

          <view class="input-group">
            <view class="input-label">验证码</view>
            <view class="verify-row">
              <input class="code-input" type="number" placeholder="请输入验证码" value="{{verifyCode}}" bindinput="onVerifyCodeInput" maxlength="4" />
              <button class="code-btn {{codeBtnDisabled ? 'disabled' : ''}}" bindtap="handleSendCode" disabled="{{codeBtnDisabled}}">{{codeBtnText}}</button>
            </view>
          </view>

          <button class="phone-login-btn" bindtap="handlePhoneLogin">登录</button>
        </view>

        <!-- 注册入口 -->
        <view class="register-entry">
          <text class="register-text">新用户？</text>
          <text class="register-link" bindtap="goToRegister">填写完整信息注册</text>
        </view>
      </view>
    </view>

    <!-- 功能说明 -->
    <view class="feature-section">
      <view class="feature-item">
        <text class="feature-icon">🔐</text>
        <text class="feature-text">微信授权安全登录</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📱</text>
        <text class="feature-text">手机验证码快捷登录</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🤝</text>
        <text class="feature-text">志愿者快速上岗接单</text>
      </view>
    </view>
  </view>

  <!-- 已登录状态：显示个人二维码 -->
  <view class="personal-qr" wx:else>
    <!-- 用户信息卡片 -->
    <view class="header-card">
      <view class="user-greeting">
        <view class="user-avatar">
          <text class="avatar-text">{{userInfo.name ? userInfo.name[0] : '用'}}</text>
        </view>
        <view class="user-detail">
          <text class="greeting-text">{{userInfo.name}}</text>
          <view class="role-tags">
            <view class="role-tag" wx:if="{{userType === 'volunteer'}}">志愿者</view>
            <view class="role-tag disabled" wx:else>视障跑者</view>
          </view>
        </view>
        <view class="logout-btn" bindtap="handleLogout">退出</view>
      </view>
    </view>

    <!-- 个人二维码 -->
    <view class="qr-section">
      <view class="qr-card">
        <view class="qr-header">
          <text class="qr-title">我的登录通行证</text>
          <text class="qr-hint">出示给{{userType === 'volunteer' ? '视障跑者' : '志愿者'}}扫描</text>
        </view>

        <!-- 二维码画布 -->
        <view class="qr-canvas-container">
          <canvas canvas-id="qrCodeCanvas" class="qr-canvas"></canvas>
          <!-- 如果有生成的二维码图片则显示图片 -->
          <image class="qr-image" wx:if="{{qrCodeUrl}}" src="{{qrCodeUrl}}" mode="aspectFit"></image>
        </view>

        <!-- 无障碍定位标记 -->
        <view class="accessibility-marks">
          <view class="mark top-left"></view>
          <view class="mark top-right"></view>
          <view class="mark bottom-left"></view>
          <view class="mark bottom-right"></view>
        </view>

        <!-- 缺口设计 -->
        <view class="notch-design">
          <view class="notch left"></view>
          <view class="notch right"></view>
        </view>

        <!-- 登录码文字 -->
        <view class="token-display">
          <text class="token-label">登录码：</text>
          <text class="token-value">{{token}}</text>
        </view>

        <!-- 操作按钮 -->
        <view class="qr-actions">
          <button class="action-btn" bindtap="refreshQRCode">
            <text class="btn-icon">🔄</text>
            <text class="btn-text">刷新</text>
          </button>
          <button class="action-btn primary" bindtap="saveQRCode">
            <text class="btn-icon">💾</text>
            <text class="btn-text">保存到相册</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 使用说明 -->
    <view class="usage-guide">
      <view class="guide-title">使用说明</view>
      <view class="guide-item">
        <text class="guide-num">1</text>
        <text class="guide-text">出示此二维码给{{userType === 'volunteer' ? '视障跑者' : '志愿者'}}扫描</text>
      </view>
      <view class="guide-item">
        <text class="guide-num">2</text>
        <text class="guide-text">{{userType === 'volunteer' ? '对方确认后开始陪跑' : '志愿者确认后开始跑步'}}</text>
      </view>
      <view class="guide-item">
        <text class="guide-num">3</text>
        <text class="guide-text">运动结束后自动记录数据</text>
      </view>
    </view>

    <!-- 紧急联系人提醒 -->
    <view class="emergency-alert" wx:if="{{userType === 'disabled'}}">
      <view class="alert-icon">⚠️</view>
      <view class="alert-content">
        <text class="alert-title">请设置紧急联系人</text>
        <text class="alert-desc">为您的安全保驾护航，紧急情况可快速联系</text>
      </view>
      <button class="alert-btn" bindtap="goToEmergencyContact">去设置</button>
    </view>
  </view>

  <!-- 紧急联系人弹窗 -->
  <view class="emergency-modal" wx:if="{{showEmergencyModal}}">
    <view class="modal-mask"></view>
    <view class="modal-content">
      <view class="modal-icon">⚠️</view>
      <view class="modal-title">请设置紧急联系人</view>
      <view class="modal-desc">为确保您的运动安全，请填写紧急联系人的信息</view>
      <button class="modal-btn" bindtap="goToEmergencyContact">立即填写</button>
      <view class="modal-skip" bindtap="closeEmergencyModal">暂不设置</view>
    </view>
  </view>
</view>
