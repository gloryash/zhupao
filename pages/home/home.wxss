}

.menu-desc {
  font-size: 24rpx;  /* 辅助说明 24rpx */
  color: #999;
}

.menu-arrow {
  font-size: 36rpx;
  color: #FFB347;
  font-weight: bold;
}

/* ==================== 4. 底部：系统支持 ==================== */
