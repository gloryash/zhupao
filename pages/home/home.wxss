/* =========================================================
   Home · Editorial Light Theme
   白底 / 暖橙强调 (与 tabBar #FF6B00 统一) / 大数字 + 英文小标
   ========================================================= */

page {
  background: #FFFFFF;
}

.home-container {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 0 28rpx 180rpx;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-feature-settings: 'tnum' 1;
}

/* ---------- 1. 个人名片 ---------- */
.profile-section { margin-bottom: 24rpx; padding-top: 28rpx; }

.profile-card {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 36rpx 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.profile-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #FF6B00 30%, #FF6B00 70%, transparent);
  opacity: 0.8;
}

.profile-header {
  display: flex;
  gap: 28rpx;
  align-items: flex-start;
}

.avatar-wrapper {
  position: relative;
  flex-shrink: 0;
}

.avatar, .avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #FFF4EC;
  border: 1rpx solid rgba(255,107,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img { width: 100%; height: 100%; }

.avatar-emoji {
  font-size: 56rpx;
  color: #FF6B00;
  font-weight: 800;
  text-transform: uppercase;
}

.role-indicator {
  position: absolute;
  bottom: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #FF6B00;
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 800;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  letter-spacing: 2rpx;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(255,107,0,0.3);
}

.role-indicator.disabled {
  background: #1A1A1A;
  color: #FFFFFF;
}

.profile-info { flex: 1; min-width: 0; }

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 44rpx;
  font-weight: 900;
  color: #1A1A1A;
  letter-spacing: -0.5rpx;
  line-height: 1.1;
}

/* 段位徽章 */
.tier-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: #FFF4EC;
  border: 1rpx solid #FF6B00;
  padding: 6rpx 14rpx;
  border-radius: 4rpx;
  position: relative;
}

.tier-badge-bg, .tier-sparkle { display: none; }

.tier-icon { width: 26rpx; height: 26rpx; flex-shrink: 0; }

.tier-name {
  font-size: 22rpx;
  font-weight: 800;
  color: #FF6B00;
  letter-spacing: 1rpx;
}

.user-tag {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-top: 4rpx;
  margin-bottom: 24rpx;
}

/* 进度条 */
.tier-progress { margin-top: 20rpx; }

.progress-bar {
  height: 6rpx;
  background: #F0F0F0;
  border-radius: 0;
  overflow: hidden;
  position: relative;
}

.progress-fill {
  height: 100%;
  transition: width 0.6s ease;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 900;
  color: #FF6B00;
  letter-spacing: 1rpx;
}

.next-level, .max-level {
  font-size: 20rpx;
  color: #9CA3AF;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* ---------- 积分与经验 ---------- */
.points-section { margin-bottom: 24rpx; }

.points-card {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.points-row { display: flex; align-items: stretch; }

.points-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.points-icon { font-size: 28rpx; opacity: 0.85; }

.points-info { display: flex; flex-direction: column; }

.points-value {
  font-size: 72rpx;
  font-weight: 900;
  color: #1A1A1A;
  line-height: 1;
  letter-spacing: -1rpx;
}

.points-label {
  font-size: 20rpx;
  color: #9CA3AF;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-top: 8rpx;
}

.points-divider {
  width: 1rpx;
  background: #F0F0F0;
  margin: 0 28rpx;
}

.checkin-tip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.checkin-icon { font-size: 22rpx; opacity: 0.6; }

.checkin-text { font-size: 22rpx; color: #666666; }

.checkin-btn {
  margin-top: 20rpx;
  width: 100%;
  background: #FF6B00;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  padding: 28rpx 0;
  border-radius: 8rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(255,107,0,0.25);
}

.checkin-btn::after { border: none; }

.checkin-btn:active { background: #E55F00; }

/* ---------- 视障教程入口 ---------- */
.tutorial-entry {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-left: 4rpx solid #FF6B00;
  border-radius: 8rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.tutorial-entry-icon { font-size: 36rpx; flex-shrink: 0; }

.tutorial-entry-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.tutorial-entry-title { font-size: 28rpx; font-weight: 800; color: #1A1A1A; }

.tutorial-entry-desc { font-size: 22rpx; color: #666666; line-height: 1.4; }

.tutorial-entry-arrow { font-size: 36rpx; color: #9CA3AF; font-weight: 300; }

/* ---------- section 头 ---------- */
.section-header-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.section-main-title {
  font-size: 24rpx;
  font-weight: 800;
  color: #1A1A1A;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

/* ---------- 培训步骤 ---------- */
.training-section { margin-bottom: 24rpx; }

.training-card {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.training-steps {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.step-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.step-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F5F5F5;
  border: 1rpx solid #E5E5E5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  color: #9CA3AF;
}

.step-item.active .step-icon {
  background: #FF6B00;
  color: #FFFFFF;
  border-color: #FF6B00;
  box-shadow: 0 0 0 6rpx rgba(255,107,0,0.15);
}

.step-item.completed .step-icon {
  background: #FFF4EC;
  color: #FF6B00;
  border-color: #FF6B00;
}

.step-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.step-name { font-size: 22rpx; color: #1A1A1A; font-weight: 600; }

.step-status { font-size: 18rpx; color: #FF6B00; letter-spacing: 1rpx; }

.step-status.pending { color: #9CA3AF; }

.step-line {
  flex: 0.5;
  height: 2rpx;
  background: #E5E5E5;
  margin: 0 -10rpx;
  margin-bottom: 50rpx;
}

.step-line.completed { background: #FF6B00; }

.training-btn {
  width: 100%;
  background: #FF6B00;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  padding: 28rpx 0;
  border-radius: 8rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(255,107,0,0.25);
}

.training-btn::after { border: none; }

.training-btn:active { background: #E55F00; }

/* ---------- 培训已完成 ---------- */
.training-completed-section {
  background: #FFF4EC;
  border: 1rpx solid rgba(255,107,0,0.3);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.completed-badge {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.completed-icon { font-size: 36rpx; }

.completed-text { font-size: 24rpx; color: #1A1A1A; font-weight: 600; }

.retrain-btn {
  background: #FFFFFF;
  border: 1rpx solid #FF6B00;
  color: #FF6B00;
  padding: 16rpx 24rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.retrain-btn::after { border: none; }

.retrain-icon { font-size: 22rpx; }

/* ---------- 2. 数据看板 ---------- */
.stats-section { margin-bottom: 24rpx; }

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stat-item {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  min-height: 180rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.stat-item::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 40rpx;
  height: 3rpx;
  background: #FF6B00;
}

.stat-icon-gradient {
  background: transparent;
  width: auto;
  height: auto;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  opacity: 0.55;
}

.stat-icon-text { font-size: 32rpx; }

.stat-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: auto;
}

.stat-number {
  font-size: 64rpx;
  font-weight: 900;
  color: #1A1A1A;
  line-height: 1;
  letter-spacing: -1rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #666666;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

/* ---------- 3. 功能列表 ---------- */
.menu-section { margin-bottom: 24rpx; }

.menu-list {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
  transition: background 0.15s;
}

.menu-item:last-child { border-bottom: none; }

.menu-item:active { background: #FFF4EC; }

.menu-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 8rpx;
  background: #FFF4EC;
  border: 1rpx solid rgba(255,107,0,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon { font-size: 28rpx; }

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.menu-title { font-size: 28rpx; color: #1A1A1A; font-weight: 700; }

.menu-desc { font-size: 22rpx; color: #9CA3AF; }

.menu-arrow { font-size: 40rpx; color: #C7C7CC; font-weight: 300; line-height: 1; }

/* ---------- 4. 底部系统支持 ---------- */
.footer-section { margin-top: 32rpx; }

.footer-menu {
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.footer-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.footer-item:last-child { border-bottom: none; }

.footer-item:active { background: #FAFAF7; }

.footer-icon { font-size: 28rpx; opacity: 0.75; }

.footer-text {
  flex: 1;
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.footer-item.logout .footer-text { color: #FF4D2E; }

.footer-item.logout .footer-icon { opacity: 1; }

/* ---------- 关于预览 ---------- */
.about-preview {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.about-logo {
  font-size: 44rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  background: #FFF4EC;
  border: 1rpx solid rgba(255,107,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.about-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.about-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #1A1A1A;
  letter-spacing: 1rpx;
}

.about-slogan {
  font-size: 20rpx;
  color: #9CA3AF;
  line-height: 1.5;
}

.about-arrow {
  font-size: 36rpx;
  color: #C7C7CC;
  font-weight: 300;
}
