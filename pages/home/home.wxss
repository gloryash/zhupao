  margin-bottom: 30rpx;
}

.stats-section .section-header-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.stats-section .section-main-title {
  font-size: 32rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;  /* 卡片间距 */
}

.stat-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;  /* 32rpx 内边距 */
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 10rpx 40rpx rgba(255, 69, 0, 0.1);
  transition: all 0.3s ease;
}

.stat-item:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 30rpx rgba(255, 69, 0, 0.15);
}

