.stat-icon-gradient {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: linear-gradient(135deg, #FF8C00 0%, #FF4500 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 69, 0, 0.2);
}

.stat-icon-text {
  font-size: 40rpx;
}

.stat-content {
  flex: 1;
  min-width: 0;
}

.stat-number {
  font-size: 56rpx;  /* 主要数值 56rpx */
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 2rpx;
}

.stat-label {
  font-size: 24rpx;  /* 辅助说明 24rpx */
  color: #999;
}

/* ==================== 3. 列表：功能操作区 ==================== */
