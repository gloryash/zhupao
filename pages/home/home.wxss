}

.checkin-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #FFF5E6;
}

.checkin-icon {
  font-size: 28rpx;
}

.checkin-text {
  font-size: 24rpx;
  color: #FF6B00;
}

.checkin-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #FF8C00 0%, #FF4500 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 20rpx;
  border: none;
  padding: 20rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(255, 69, 0, 0.25);
  transition: all 0.2s ease;
}

.checkin-btn::after {
  border: none;
}

.checkin-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 69, 0, 0.35);
}

.user-tag {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
}

/* ==================== 2. 中间：数据看板 ==================== */
