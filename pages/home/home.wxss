  min-width: 0;
}

.about-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.about-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  line-height: 1.5;
}

.about-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: bold;
}

/* ==================== 悬浮主要功能按钮 ==================== */
.float-action {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 0 100rpx;
  height: 110rpx;
  border-radius: 55rpx;
  background: linear-gradient(135deg, #FF8C00 0%, #FF4500 100%);
  box-shadow: 0 10rpx 40rpx rgba(255, 69, 0, 0.35), 0 0 60rpx rgba(255, 140, 0, 0.2);
  transition: all 0.3s ease;
  animation: breathe 3s ease-in-out infinite;
}

.action-btn:active {
  transform: scale(0.95);
  box-shadow: 0 6rpx 30rpx rgba(255, 69, 0, 0.4);
}

/* 呼吸感动画 */
@keyframes breathe {
  0%, 100% {
    box-shadow: 0 10rpx 40rpx rgba(255, 69, 0, 0.35), 0 0 60rpx rgba(255, 140, 0, 0.2);
  }
  50% {
    box-shadow: 0 12rpx 50rpx rgba(255, 69, 0, 0.45), 0 0 80rpx rgba(255, 140, 0, 0.3);
  }
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF8C00 0%, #FF4500 100%);
}

.action-btn.volunteer {
  background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%);
}

/* 锁定状态 */
.action-btn.btn-locked {
  background: linear-gradient(135deg, rgba(255, 140, 0, 0.4) 0%, rgba(255, 69, 0, 0.4) 100%);
  box-shadow: none;
  animation: none;
}

.action-btn.btn-locked:active {
  transform: none;
}

.btn-icon {
  font-size: 40rpx;
}

.btn-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* 锁定状态小锁图标 */
.lock-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

/* ==================== 动画效果 ==================== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.profile-section,
.stats-section,
.menu-section,
.footer-section {
  animation: fadeInUp 0.6s ease-out forwards;
}

.stats-section {
  animation-delay: 0.1s;
}

.menu-section {
  animation-delay: 0.2s;
}

.footer-section {
  animation-delay: 0.3s;
}

/* ==================== 志愿者上岗引导弹窗 ==================== */
.certificate-guide-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.guide-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.guide-content {
  position: relative;
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  animation: guidePopup 0.3s ease-out;
}

@keyframes guidePopup {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.guide-header {
  background: linear-gradient(135deg, #FF6B00 0%, #FF8C00 100%);
  padding: 40rpx 32rpx;
  text-align: center;
}

.guide-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.guide-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.guide-body {
  padding: 32rpx;
}

.guide-desc {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.guide-steps {
  background: #FFF5E6;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.guide-step {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #FF6B00 0%, #FF4500 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-text {
  font-size: 26rpx;
  color: #333;
}

.guide-actions {
  padding: 0 32rpx 32rpx;
}

.guide-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: none;
}

.guide-btn::after {
  border: none;
}

.guide-btn.primary {
  background: linear-gradient(135deg, #FF6B00 0%, #FF4500 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.3);
}

.guide-btn.secondary {
  background: #F5F5F5;
  color: #666;
}
