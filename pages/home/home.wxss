  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 69, 0, 0.2);
}

.footer-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

/* 关于我们预览 */
.about-preview {
  background: linear-gradient(135deg, #FF8C00 0%, #FF4500 100%);
  border-radius: 24rpx;
  padding: 40rpx;
