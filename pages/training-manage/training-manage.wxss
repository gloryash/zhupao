/* 页面容器 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

/* 操作按钮区 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  height: 100rpx;
  background: linear-gradient(135deg, #1890ff 0%, #0066cc 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 20rpx;
  border: none;
  box-shadow: 0 4rpx 15rpx rgba(24, 144, 255, 0.3);
}

.action-btn::after {
  border: none;
}

.video-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a52 100%);
  box-shadow: 0 4rpx 15rpx rgba(255, 107, 107, 0.3);
}

.doc-btn {
  background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
  box-shadow: 0 4rpx 15rpx rgba(81, 207, 102, 0.3);
}

.exam-btn {
  background: linear-gradient(135deg, #ffd43b 0%, #fab005 100%);
  box-shadow: 0 4rpx 15rpx rgba(255, 212, 59, 0.3);
}

.records-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.3);
}

/* 区块 */
.section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 教程列表 */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.course-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 15rpx;
}

.course-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.course-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.course-meta {
  font-size: 24rpx;
  color: #999;
}

.delete-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #ff6b6b;
  color: #fff;
  font-size: 24rpx;
  border-radius: 10rpx;
  border: none;
  padding: 0;
}

.delete-btn::after {
  border: none;
}

/* 考试列表 */
.exam-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.exam-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 15rpx;
}

.exam-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.exam-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.exam-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.exam-meta {
  font-size: 24rpx;
  color: #999;
}

/* 空状态提示 */
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
