/* 页面容器 */
.login-container {
  min-height: 100vh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
}

/* 顶部插画区域 */
.hero-section {
  position: relative;
  height: 45vh;
  background: linear-gradient(135deg, #E0F7FA 0%, #E8F5E9 50%, #F1F8E9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 插画容器 */
.illustration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
}

.illustration-img {
  width: 100%;
  height: 100%;
}

/* 欢迎文字 */
.welcome-text {
  position: relative;
  z-index: 2;
  text-align: center;
  margin-top: 20vh;
}

.welcome-title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #2ED085 0%, #1DBE73 50%, #07C160 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.welcome-subtitle {
  display: block;
  font-size: 28rpx;
  color: #66BB6A;
  margin-top: 16rpx;
  font-weight: 400;
}

/* 装饰圆圈 */
.deco-circle {
  position: absolute;
  border-radius: 50%;
  z-index: 1;
}

.deco-1 {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%);
  opacity: 0.2;
  top: 10%;
  right: 10%;
  animation: float 6s ease-in-out infinite;
}

.deco-2 {
  width: 150rpx;
  height: 150rpx;
  background: linear-gradient(135deg, #81D4FA 0%, #4FC3F7 100%);
  opacity: 0.2;
  bottom: 15%;
  left: 5%;
  animation: float 8s ease-in-out infinite reverse;
}

.deco-3 {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #CE93D8 0%, #BA68C8 100%);
  opacity: 0.15;
  top: 30%;
  left: 15%;
  animation: float 7s ease-in-out infinite 1s;
}

/* 浮动动画 */
@keyframes float {
  0%, 100% {
    transform: translateY(0) scale(1);
  }
  50% {
    transform: translateY(-20rpx) scale(1.05);
  }
}

/* 表单区域 */
.form-section {
  position: relative;
  z-index: 10;
  margin-top: -60rpx;
  padding: 0 40rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 60rpx 60rpx 0 0;
  padding: 60rpx 50rpx 40rpx;
  box-shadow: 0 -20rpx 60rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
  padding-left: 10rpx;
}

.form-input {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #F5F5F5 0%, #EEEEEE 100%);
  border-radius: 24rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.form-input:focus {
  background: #FFFFFF;
  border-color: #2ED085;
  outline: none;
  box-shadow: 0 4rpx 20rpx rgba(46, 208, 133, 0.15);
}

/* 手机号输入行 */
.phone-input-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.phone-input {
  flex: 1;
}

/* 获取验证码按钮 */
.get-code-btn {
  width: 200rpx;
  height: 80rpx;
  background: #CCCCCC;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.get-code-btn::after {
  border: none;
}

.get-code-btn.active {
  background: linear-gradient(90deg, #2ED085 0%, #07C160 100%);
}

.get-code-btn[disabled] {
  opacity: 0.7;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(90deg, #2ED085 0%, #1DBE73 50%, #07C160 100%);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 50rpx;
  border: none;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(46, 208, 133, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 4rpx;
  transition: all 0.3s ease;
}

.login-btn::after {
  border: none;
}

.login-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 40rpx rgba(46, 208, 133, 0.45);
}

.login-btn:active {
  transform: translateY(0);
}

/* 开发者提示 */
.dev-tip {
  display: block;
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: #B0B0B0;
}

/* 底部说明 */
.footer-section {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  padding: 40rpx 60rpx 60rpx;
  background: #FFFFFF;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}

.footer-link {
  font-size: 24rpx;
  color: #07C160;
  margin: 0 4rpx;
}

/* 响应式调整 */
@media (min-width: 750rpx) {
  .welcome-title {
    font-size: 72rpx;
  }

  .welcome-subtitle {
    font-size: 32rpx;
  }

  .form-card {
    max-width: 600rpx;
    margin: 0 auto;
    padding: 70rpx 60rpx 50rpx;
  }
}
