/* 陪跑记录管理页面 */
.records-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 120rpx;
}

/* 顶部统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 30rpx;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 搜索栏 */
.search-bar {
  padding: 0 30rpx 20rpx;
}

.search-input-wrapper {
  background-color: #ffffff;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f2f5;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  margin: 0 10rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-weight: 600;
}

/* 记录列表 */
.records-list {
  padding: 20rpx 30rpx;
  height: calc(100vh - 400rpx);
}

/* 记录卡片 */
.record-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

/* 卡片头部 */
.record-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.record-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-icon {
  font-size: 40rpx;
}

.record-info {
  flex: 1;
}

.record-names {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-distance {
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: baseline;
}

.record-distance .distance-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.record-distance .distance-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 4rpx;
}

/* 卡片详情 */
.record-detail {
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  gap: 20rpx;
}

.detail-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.detail-icon {
  font-size: 28rpx;
}

.detail-text {
  font-size: 26rpx;
  color: #666;
}

/* 评分显示 */
.record-rating {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.rating-badge {
  background-color: #fffbeb;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #f59e0b;
}

/* 操作按钮 */
.record-actions {
  display: flex;
  justify-content: flex-end;
  border-top: 1rpx solid #f0f2f5;
  padding-top: 16rpx;
  margin-top: 8rpx;
}

.action-btn {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  margin-left: 16rpx;
}

.action-btn.delete {
  background-color: #fef2f2;
  color: #ef4444;
}

.action-btn.call {
  background-color: #ecfdf5;
  color: #07c160;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.action-row {
  display: flex;
  gap: 20rpx;
}

.export-btn,
.clear-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.export-btn::after,
.clear-btn::after {
  border: none;
}

.export-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.clear-btn {
  background-color: #ffffff;
  color: #ef4444;
  border: 2rpx solid #ef4444;
}

.btn-icon {
  font-size: 32rpx;
}
