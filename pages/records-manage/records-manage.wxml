<!-- 陪跑记录管理页面 -->
<view class="records-page">
  <!-- 顶部统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{stats.total}}</text>
      <text class="stat-label">陪跑次数</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.totalDistance}}</text>
      <text class="stat-label">总里程(km)</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.totalHours}}</text>
      <text class="stat-label">总时长(h)</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索志愿者/盲人名字/地点"
        bindinput="onSearchInput"
        value="{{searchKeyword}}"
      />
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
      <text>全部</text>
    </view>
    <view class="tab-item {{currentTab === 'volunteer' ? 'active' : ''}}" bindtap="switchTab" data-tab="volunteer">
      <text>志愿者</text>
    </view>
    <view class="tab-item {{currentTab === 'blind' ? 'active' : ''}}" bindtap="switchTab" data-tab="blind">
      <text>视障者</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <scroll-view class="records-list" scroll-y="true" wx:if="{{filteredRecords.length > 0}}">
    <block wx:for="{{filteredRecords}}" wx:key="id">
      <view class="record-card" bindtap="viewDetail" data-id="{{item.id}}">
        <!-- 卡片头部 -->
        <view class="record-header">
          <view class="record-avatar">
            <text class="avatar-icon">{{item.blindAvatar || '👤'}}</text>
          </view>
          <view class="record-info">
            <text class="record-names">{{item.blindName || '视障跑者'}} + {{item.volunteerName || '志愿者'}}</text>
            <text class="record-time">{{formatTime(item.completedTime)}}</text>
          </view>
          <view class="record-distance">
            <text class="distance-value">{{item.actualDistance || '--'}}</text>
            <text class="distance-unit">km</text>
          </view>
        </view>

        <!-- 卡片详情 -->
        <view class="record-detail">
          <view class="detail-row">
            <view class="detail-item">
              <text class="detail-icon">🎯</text>
              <text class="detail-text">目标：{{item.targetDistance || '--'}}</text>
            </view>
            <view class="detail-item">
              <text class="detail-icon">⏱️</text>
              <text class="detail-text">用时：{{item.duration ? item.duration + '分钟' : '--'}}</text>
            </view>
          </view>
        </view>

        <!-- 评分显示 -->
        <view class="record-rating" wx:if="{{item.blindRate || item.volunteerRate}}">
          <view class="rating-badge" wx:if="{{item.blindRate}}">
            <text>盲人评{{item.blindRate}}★</text>
          </view>
          <view class="rating-badge" wx:if="{{item.volunteerRate}}">
            <text>志愿者评{{item.volunteerRate}}★</text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="record-actions">
          <!-- 拨打电话按钮（仅当有志愿者电话时显示） -->
          <view class="action-btn call" catchtap="callVolunteer" data-id="{{item.id}}" wx:if="{{item.volunteerPhone}}">
            <text>📞 联系</text>
          </view>
          <view class="action-btn delete" catchtap="deleteRecord" data-id="{{item.id}}">
            <text>删除</text>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无陪跑记录</text>
    <text class="empty-hint">当志愿者完成陪跑后，记录会自动保存到这里</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-actions" wx:if="{{records.length > 0}}">
    <view class="action-row">
      <button class="export-btn" bindtap="exportAllRecords">
        <text class="btn-icon">📤</text>
        导出全部
      </button>
      <button class="clear-btn" bindtap="clearAllRecords">
        <text class="btn-icon">🗑️</text>
        清除全部
      </button>
    </view>
  </view>
</view>
