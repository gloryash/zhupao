/* pages/certificate/certificate.wxss */

/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

/* 证书卡片 */
.certificate-card {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.3);
  position: relative;
}

/* 证书头部 */
.certificate-header {
  text-align: center;
  margin-bottom: 50rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.header-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.header-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 证书内容 */
.certificate-content {
  margin-bottom: 40rpx;
}

.content-row {
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  width: 180rpx;
}

.value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.value.highlight {
  color: #1890ff;
  font-size: 32rpx;
}

/* 证书说明 */
.certificate-desc {
  background-color: #f8f9fa;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 证书底部 */
.certificate-footer {
  text-align: center;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.footer-text {
  font-size: 28rpx;
  color: #999;
}

/* 操作按钮区域 */
.action-section {
  width: 100%;
  margin-top: 40rpx;
}

.home-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
}

.home-btn::after {
  border: none;
}

/* 视障人士提示 */
.disabled-tip {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.tip-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.tip-content {
  margin-bottom: 40rpx;
}

.tip-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tip-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 10rpx;
}

.tip-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
}

.tip-btn::after {
  border: none;
}

/* 无证书提示 */
.no-certificate {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 80rpx 40rpx;
  width: 100%;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.no-cert-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.no-cert-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.no-cert-desc {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.no-cert-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
}

.no-cert-btn::after {
  border: none;
}

/* 数字身份牌区域 */
.id-card-section {
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  width: 100%;
  margin-top: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.id-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.id-icon {
  font-size: 48rpx;
}

.id-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
}

.id-card-content {
  display: flex;
  flex-direction: column;
}

.id-desc {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 30rpx;
  line-height: 1.5;
}

/* 数字身份牌预览 */
.id-card-preview {
  margin-bottom: 30rpx;
}

.id-card-front {
  background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

.id-card-front::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
}

.id-card-logo {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 30rpx;
}

.logo-icon {
  font-size: 40rpx;
}

.logo-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.id-card-info {
  margin-bottom: 30rpx;
}

.id-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.id-role {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #fff;
}

.id-token {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.token-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.token-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  font-family: monospace;
  letter-spacing: 2rpx;
}

/* 身份牌操作按钮 */
.id-card-actions {
  display: flex;
  gap: 20rpx;
}

.claim-btn,
.view-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
}

.claim-btn {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.view-btn {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.claim-btn::after,
.view-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}