<view class="appointment-square">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-title">预约广场</view>
    <view class="header-subtitle">查看附近的预约陪跑需求</view>
  </view>

  <!-- 预约列表 -->
  <view class="appointment-list" wx:if="{{appointments.length > 0}}">
    <view class="appointment-card" wx:for="{{appointments}}" wx:key="id" bindtap="viewAppointment" data-id="{{item.id}}">
      <!-- 卡片头部 -->
      <view class="card-header">
        <view class="card-date">
          <text class="date-day">{{item.dateDay}}</text>
          <text class="date-month">{{item.dateMonth}}</text>
        </view>
        <view class="card-info">
          <view class="info-row">
            <text class="info-icon">⏰</text>
            <text class="info-text">{{item.appointmentTime}}</text>
          </view>
          <view class="info-row">
            <text class="info-icon">⏱️</text>
            <text class="info-text">{{item.duration}}</text>
          </view>
        </view>
        <view class="status-badge {{item.status}}">
          {{item.statusText}}
        </view>
      </view>

      <!-- 盲人信息 -->
      <view class="blind-info">
        <view class="blind-avatar">{{item.blindName[0]}}</view>
        <view class="blind-details">
          <view class="blind-name-row">
            <text class="blind-name">{{item.blindName}}</text>
            <!-- 性别标记 -->
            <view class="gender-badge {{item.blindGender === 'male' ? 'male' : 'female'}}" wx:if="{{item.blindGender}}">
              <text class="gender-icon">{{item.blindGender === 'male' ? '♂' : '♀'}}</text>
              <text class="gender-text">{{item.blindGender === 'male' ? '男' : '女'}}</text>
            </view>
          </view>
          <text class="blind-address">{{item.blindAddress}}</text>
        </view>
        <button class="call-btn" bindtap="contactBlind" data-phone="{{item.blindPhone}}" wx:if="{{item.status !== 'pending'}}">
          📞
        </button>
      </view>

      <!-- 备注信息 -->
      <view class="notes-section" wx:if="{{item.notes}}">
        <text class="notes-icon">📝</text>
        <text class="notes-text">{{item.notes}}</text>
      </view>

      <!-- 距离信息 -->
      <view class="distance-info">
        <text class="distance-icon">📍</text>
        <text class="distance-text">距您 {{item.distance}} km</text>
      </view>

      <!-- 操作按钮 -->
      <view class="card-actions">
        <button class="action-btn accept-btn" bindtap="acceptAppointment" data-id="{{item.id}}" wx:if="{{item.status === 'pending'}}">
          接单
        </button>
        <button class="action-btn contact-btn" bindtap="contactBlind" data-phone="{{item.blindPhone}}" wx:if="{{item.status === 'accepted'}}">
          联系盲人
        </button>
        <button class="action-btn nav-btn" bindtap="navigateToLocation" data-lat="{{item.blindLatitude}}" data-lng="{{item.blindLongitude}}" wx:if="{{item.status === 'accepted'}}">
          导航前往
        </button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-icon">📭</view>
    <text class="empty-title">暂无预约</text>
    <text class="empty-desc">暂时没有待接单的预约陪跑需求</text>
  </view>

  <!-- 刷新按钮 -->
  <view class="refresh-btn" bindtap="refreshAppointments" wx:if="{{appointments.length > 0}}">
    <text>🔄 刷新</text>
  </view>
</view>
