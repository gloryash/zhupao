.appointment-square {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部标题 */
.header {
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
  padding: 40rpx 30rpx;
  padding-top: calc(40rpx + env(safe-area-inset-top));
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 预约列表 */
.appointment-list {
  padding: 20rpx;
}

.appointment-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
  border-radius: 16rpx;
  margin-right: 24rpx;
}

.date-day {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}

.date-month {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
}

.card-info {
  flex: 1;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.info-text {
  font-size: 28rpx;
  color: #333;
}

/* 状态标签 */
.status-badge {
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.status-badge.pending {
  background: #FFF7E6;
  color: #D48806;
}

.status-badge.accepted {
  background: #E6F7FF;
  color: #1890FF;
}

.status-badge.completed {
  background: #F6FFED;
  color: #07C160;
}

/* 盲人信息 */
.blind-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.blind-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160 0%, #06AE56 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  margin-right: 20rpx;
}

.blind-details {
  flex: 1;
}

.blind-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.blind-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

/* 性别标记 */
.gender-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}

.gender-badge.male {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  color: #1976D2;
}

.gender-badge.female {
  background: linear-gradient(135deg, #FCE4EC 0%, #F8BBD9 100%);
  color: #C2185B;
}

.gender-icon {
  font-size: 22rpx;
  font-weight: bold;
}

.gender-text {
  font-weight: 500;
}

.blind-address {
  font-size: 26rpx;
  color: #999;
}

.call-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160 0%, #06AE56 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border: none;
}

.call-btn::after {
  border: none;
}

/* 备注信息 */
.notes-section {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.notes-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.notes-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
  line-height: 1.4;
}

/* 距离信息 */
.distance-info {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.distance-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.distance-text {
  font-size: 28rpx;
  color: #666;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}

.accept-btn {
  background: linear-gradient(135deg, #07C160 0%, #06AE56 100%);
  color: #fff;
}

.contact-btn {
  background: #f5f5f5;
  color: #333;
}

.nav-btn {
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

/* 刷新按钮 */
.refresh-btn {
  position: fixed;
  bottom: 40rpx;
  right: 30rpx;
  background: #fff;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  font-size: 28rpx;
  color: #333;
}
