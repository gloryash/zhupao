/* =========================================================
   publish-need · 打车式发布流程
   全屏地图 / 底部浮动面板 / 4 步流程 + 发布后状态
   ========================================================= */

.map-page {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.fullscreen-map {
  width: 100%;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

/* ---------- 顶部状态栏（发布后） ---------- */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 80rpx 30rpx 20rpx;
}

.location-info-bar {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.18);
}

.location-info-bar.waiting { border-left: 6rpx solid #FF6B00; }
.location-info-bar.accepted { border-left: 6rpx solid #07C160; }

.location-icon { font-size: 32rpx; }
.location-text { font-size: 26rpx; color: #1A1A1A; font-weight: 600; }

.accepted-badge { display: flex; align-items: center; gap: 12rpx; }
.badge-icon { font-size: 36rpx; }
.badge-text { font-size: 26rpx; color: #1A1A1A; font-weight: 700; }

/* ---------- 右侧重定位 ---------- */
.map-controls {
  position: fixed;
  right: 30rpx;
  bottom: 720rpx;
  z-index: 10;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.18);
}

.control-icon { font-size: 36rpx; }

/* ---------- 左侧安全控制 ---------- */
.safety-controls {
  position: fixed;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.safety-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.safety-btn.emergency { background: #FF3B30; }
.safety-btn.contact { background: #1890FF; }
.safety-btn.complaint { background: #FF9500; }

.safety-icon { font-size: 32rpx; }
.safety-label { font-size: 18rpx; color: #FFFFFF; font-weight: 700; }

/* ---------- 底部浮动面板 ---------- */
.bottom-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: #FFFFFF;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 28rpx 28rpx 40rpx;
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.08);
  max-height: 80vh;
  overflow-y: auto;
}

/* ---------- 进度点 ---------- */
.step-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  padding: 0 40rpx;
}

.step-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #F0F0F0;
  color: #9CA3AF;
  font-size: 22rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.step-dot.active {
  background: #FF6B00;
  color: #FFFFFF;
  box-shadow: 0 0 0 6rpx rgba(255,107,0,0.18);
}

.step-dot.done {
  background: #FFF4EC;
  color: #FF6B00;
  border: 1rpx solid #FF6B00;
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: #E5E5E5;
  margin: 0 -2rpx;
}

.step-line.done { background: #FF6B00; }

/* ---------- 标题 / 副标 ---------- */
.step-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #1A1A1A;
  margin-top: 12rpx;
  text-align: center;
  letter-spacing: -0.5rpx;
}

.step-subtitle {
  font-size: 24rpx;
  color: #666666;
  text-align: center;
  margin-top: 6rpx;
  margin-bottom: 24rpx;
}

/* ---------- 已选地址卡片 ---------- */
.selected-address {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FAFAF7;
  border: 1rpx solid #EEEEEE;
  border-radius: 12rpx;
  padding: 24rpx 22rpx;
  margin-bottom: 16rpx;
}

.addr-icon {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.addr-icon.start {
  background: #07C160;
  box-shadow: 0 0 0 4rpx rgba(7,193,96,0.2);
}

.addr-icon.end {
  background: #FF3B30;
  box-shadow: 0 0 0 4rpx rgba(255,59,48,0.2);
}

.addr-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.addr-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.addr-detail {
  font-size: 22rpx;
  color: #9CA3AF;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.addr-edit {
  font-size: 24rpx;
  color: #FF6B00;
  font-weight: 700;
  flex-shrink: 0;
  padding: 8rpx 12rpx;
}

/* ---------- 主操作：去地图选点 ---------- */
.map-pick-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FFF4EC;
  border: 2rpx dashed #FF6B00;
  border-radius: 12rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
}

.pick-icon { font-size: 40rpx; }

.pick-text {
  flex: 1;
  font-size: 28rpx;
  color: #FF6B00;
  font-weight: 700;
}

.pick-arrow {
  font-size: 36rpx;
  color: #FF6B00;
  font-weight: 300;
}

/* ---------- 历史地址 ---------- */
.history-section { margin-bottom: 16rpx; }

.history-label {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 800;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 22rpx;
  background: #FFFFFF;
  border: 1rpx solid #EEEEEE;
  border-radius: 10rpx;
}

.history-item:active { background: #FAFAF7; }

.history-icon { font-size: 24rpx; opacity: 0.6; }

.history-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.history-name {
  font-size: 26rpx;
  color: #1A1A1A;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-addr {
  font-size: 20rpx;
  color: #9CA3AF;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ---------- 时长 chip 网格 ---------- */
.duration-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.duration-chip {
  background: #FFFFFF;
  border: 2rpx solid #EEEEEE;
  border-radius: 12rpx;
  padding: 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.duration-chip:active { transform: scale(0.96); }

.duration-chip.active {
  background: #FF6B00;
  border-color: #FF6B00;
  box-shadow: 0 4rpx 14rpx rgba(255,107,0,0.3);
}

.chip-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #1A1A1A;
}

.duration-chip.active .chip-text {
  color: #FFFFFF;
  font-weight: 900;
}

.duration-hint {
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
  margin-bottom: 12rpx;
}

/* ---------- 确认摘要卡 ---------- */
.summary-card {
  background: #FAFAF7;
  border: 1rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 12rpx 0;
}

.summary-divider {
  height: 1rpx;
  background: #EEEEEE;
  margin: 4rpx 0;
}

.summary-icon {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.summary-icon.start {
  background: #07C160;
  box-shadow: 0 0 0 4rpx rgba(7,193,96,0.2);
}

.summary-icon.end {
  background: #FF3B30;
  box-shadow: 0 0 0 4rpx rgba(255,59,48,0.2);
}

.summary-icon-emoji {
  font-size: 24rpx;
  width: 18rpx;
  text-align: center;
}

.summary-text {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  min-width: 0;
}

.summary-label {
  font-size: 24rpx;
  color: #9CA3AF;
  letter-spacing: 1rpx;
}

.summary-value {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 700;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 380rpx;
}

/* ---------- 底部操作按钮 ---------- */
.action-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-top: 8rpx;
}

.back-btn {
  padding: 28rpx 32rpx;
  font-size: 26rpx;
  color: #666666;
  font-weight: 700;
}

.back-btn:active { color: #1A1A1A; }

.next-btn {
  flex: 1;
  background: #FF6B00;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  padding: 28rpx 0;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 18rpx rgba(255,107,0,0.3);
}

.next-btn::after { border: none; }

.next-btn:active { background: #E55F00; }

.next-btn.disabled {
  background: #E5E5E5;
  color: #9CA3AF;
  box-shadow: none;
}

/* =========================================================
   发布后：等待中 / 已接单 状态（沿用旧设计精简版）
   ========================================================= */

.waiting-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
}

.waiting-animation {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.pulse-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 4rpx solid #FF6B00;
  border-radius: 50%;
  animation: pulse 2s ease-out infinite;
  opacity: 0;
}

.pulse-ring.delay-1 { animation-delay: 0.6s; }
.pulse-ring.delay-2 { animation-delay: 1.2s; }

@keyframes pulse {
  0% { transform: scale(0.4); opacity: 1; }
  100% { transform: scale(1); opacity: 0; }
}

.pulse-icon {
  font-size: 72rpx;
  z-index: 1;
}

.waiting-text {
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.waiting-hint {
  font-size: 24rpx;
  color: #9CA3AF;
}

.cancel-link {
  font-size: 24rpx;
  color: #FF3B30;
  margin-top: 28rpx;
  padding: 14rpx 24rpx;
  font-weight: 700;
}

/* ---------- 已接单 ---------- */
.volunteer-info { padding: 12rpx 0; }

.volunteer-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.volunteer-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #FFF4EC;
  border: 2rpx solid #FF6B00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.volunteer-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.volunteer-name {
  font-size: 32rpx;
  font-weight: 900;
  color: #1A1A1A;
}

.volunteer-status {
  font-size: 22rpx;
  color: #07C160;
  font-weight: 600;
}

.distance-badge {
  background: #07C160;
  color: #FFFFFF;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
}

.distance-value {
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
}

.distance-unit {
  font-size: 18rpx;
  letter-spacing: 1rpx;
  margin-top: 2rpx;
}

.volunteer-actions {
  display: flex;
  gap: 16rpx;
}

.call-btn, .cancel-btn {
  flex: 1;
  font-size: 28rpx;
  font-weight: 800;
  padding: 24rpx 0;
  border-radius: 10rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.call-btn::after, .cancel-btn::after { border: none; }

.call-btn {
  background: #07C160;
  color: #FFFFFF;
  box-shadow: 0 4rpx 14rpx rgba(7,193,96,0.3);
}

.cancel-btn {
  background: #FFFFFF;
  color: #FF3B30;
  border: 2rpx solid #FF3B30;
}

.btn-icon { font-size: 28rpx; }
