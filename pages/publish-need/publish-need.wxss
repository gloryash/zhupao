/* 页面容器 - 全屏布局 */
.map-page {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 全屏地图 */
.fullscreen-map {
  width: 100%;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

/* 顶部信息栏 */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3), transparent);
  padding: 40rpx 30rpx 60rpx;
}

.location-info-bar {
  background-color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.location-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.location-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 右侧地图控制按钮 */
.map-controls {
  position: fixed;
  right: 30rpx;
  bottom: 350rpx;
  z-index: 10;
}

.control-btn {
  background-color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.control-icon {
  font-size: 32rpx;
}

.control-label {
  font-size: 24rpx;
  color: #333;
}

/* 底部浮动操作面板 - 类似滴滴 */
.bottom-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: linear-gradient(to top, rgba(0,0,0,0.05), transparent);
  padding: 40rpx 0 0;
}

.panel-content {
  background-color: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 50rpx 40rpx;
  box-shadow: 0 -4rpx 30rpx rgba(0,0,0,0.1);
}

.info-section {
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  display: block;
}

/* 需求详情输入 */
.need-details {
  margin-bottom: 30rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.picker-view {
  font-size: 30rpx;
  color: #1890ff;
  font-weight: bold;
  padding: 10rpx 20rpx;
  background-color: #f0f9ff;
  border-radius: 10rpx;
}

/* 发布按钮 - 类似滴滴的主操作按钮 */
.publish-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.publish-btn::after {
  border: none;
}

/* 已点亮状态 */
.publish-btn.lighted {
  background: linear-gradient(135deg, #999 0%, #666 100%);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

/* 等待中状态栏 */
.location-info-bar.waiting {
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
}

.location-info-bar.waiting .location-text {
  color: #fff;
}

.location-info-bar.waiting .location-icon {
  animation: blink 1s ease-in-out infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 已接单状态栏 */
.location-info-bar.accepted {
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  padding: 16rpx 24rpx;
}

.accepted-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.badge-icon {
  font-size: 32rpx;
}

.badge-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* 等待中动画 */
.waiting-info {
  text-align: center;
  padding: 40rpx 0;
}

.waiting-animation {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 24rpx;
}

.pulse-ring,
.pulse-icon {
  position: absolute;
  border-radius: 50%;
}

.pulse-ring {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.3) 0%, rgba(245, 124, 0, 0.3) 100%);
  animation: pulse-ring 2s ease-out infinite;
}

.pulse-ring.delay-1 {
  animation-delay: 0.3s;
  transform: scale(0.85);
}

.pulse-ring.delay-2 {
  animation-delay: 0.6s;
  transform: scale(0.7);
}

@keyframes pulse-ring {
  0% {
    transform: scale(1);
    opacity: 0.6;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

.pulse-icon {
  font-size: 60rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.waiting-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff9800;
  display: block;
  margin-bottom: 12rpx;
}

.waiting-hint {
  font-size: 26rpx;
  color: #999;
}

/* 志愿者信息卡片 */
.volunteer-info {
  padding: 0;
}

.volunteer-header {
  display: flex;
  align-items: center;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.volunteer-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.volunteer-details {
  flex: 1;
}

.volunteer-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.volunteer-status {
  font-size: 26rpx;
  color: #07c160;
}

.distance-badge {
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: baseline;
}

.distance-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.distance-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 6rpx;
}

/* 志愿者操作按钮 */
.volunteer-actions {
  display: flex;
  gap: 20rpx;
}

.call-btn {
  flex: 2;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 20rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.call-btn::after {
  border: none;
}

.cancel-btn {
  flex: 1;
  height: 88rpx;
  background: #fff;
  color: #999;
  font-size: 30rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.cancel-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

/* 左侧安全功能按钮 */
.safety-controls {
  position: fixed;
  left: 30rpx;
  bottom: 350rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.safety-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.safety-btn.emergency {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  animation: pulse-emergency 2s ease-in-out infinite;
}

.safety-btn.contact {
  background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
}

.safety-btn.complaint {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

@keyframes pulse-emergency {
  0% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.5);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 0 0 20rpx rgba(239, 68, 68, 0);
  }
  100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
  }
}

.safety-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.safety-label {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}
