/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

/* 验证表单 */
.verify-form {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.3);
}

.form-header {
  text-align: center;
  margin-bottom: 50rpx;
}

.header-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 表单主体 */
.form-body {
  margin-bottom: 20rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.input-field {
  width: 100%;
  height: 80rpx;
  background-color: #f8f9fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  border: 2rpx solid #e0e0e0;
}

.verify-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #1890ff 0%, #0066cc 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(24, 144, 255, 0.3);
}

.verify-btn::after {
  border: none;
}

/* 验证结果 */
.verify-result {
  width: 100%;
}

.result-card {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.3);
  text-align: center;
}

.result-card.success {
  border-top: 8rpx solid #07c160;
}

.result-card.fail {
  border-top: 8rpx solid #ff6b6b;
}

.result-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.result-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
}

.result-card.success .result-title {
  color: #07c160;
}

.result-card.fail .result-title {
  color: #ff6b6b;
}

.result-info {
  text-align: left;
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  width: 180rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  font-weight: 500;
}

.reset-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
  margin-top: 20rpx;
}

.reset-btn::after {
  border: none;
}
