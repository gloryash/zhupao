/* pages/shop/shop.wxss */

/* 容器 */
.shop-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f0f23 100%);
  padding-bottom: 120rpx;
}

/* 积分卡片 */
.points-card {
  margin: 30rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
}

.points-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  opacity: 0.9;
}

.points-pattern {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 60%;
  height: 200%;
  background: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 20rpx,
    rgba(255, 255, 255, 0.1) 20rpx,
    rgba(255, 255, 255, 0.1) 40rpx
  );
}

.points-content {
  position: relative;
  z-index: 1;
  padding: 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.points-icon {
  font-size: 80rpx;
}

.points-info {
  flex: 1;
}

.points-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.points-value {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  transition: all 0.3s ease;
}

.points-value.animating {
  transform: scale(1.2);
  color: #ffd700;
}

.points-actions {
  flex-shrink: 0;
}

.points-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  border: none;
  backdrop-filter: blur(10rpx);
}

.points-btn::after {
  border: none;
}

.points-btn .btn-icon {
  font-size: 28rpx;
}

.points-btn .btn-text {
  font-size: 24rpx;
  color: #fff;
}

/* 公告栏 */
.notice-bar {
  margin: 0 30rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  backdrop-filter: blur(10rpx);
}

.notice-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
  height: 40rpx;
  overflow: hidden;
  position: relative;
}

.notice-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  position: absolute;
  width: 100%;
  opacity: 0;
  transform: translateY(100%);
  transition: all 0.5s ease;
}

.notice-item.show {
  opacity: 1;
  transform: translateY(0);
}

/* 分类栏 */
.category-bar {
  margin: 30rpx 0;
  padding: 0 20rpx;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.category-item.active {
  background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%);
  border-color: #fff;
}

.category-name {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  white-space: nowrap;
}

.category-item.active .category-name {
  color: #1a1a2e;
  font-weight: bold;
}

/* 商品宫格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 20rpx;
}

.product-card {
  width: calc(33.333% - 14rpx);
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  overflow: hidden;
  backdrop-filter: blur(10rpx);
  transition: all 0.3s ease;
}

.product-card:active {
  transform: scale(0.95);
}

.product-image {
  width: 100%;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  position: relative;
}

.product-emoji {
  font-size: 100rpx;
}

.sold-out-tag {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  padding: 4rpx 12rpx;
  background: rgba(239, 68, 68, 0.9);
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #fff;
}

.limit-tag {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #fff;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.price-icon {
  font-size: 24rpx;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffd700;
}

.product-stats {
  flex-shrink: 0;
}

.sold-count {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 底部提示 */
.shop-tip {
  padding: 40rpx;
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
}

/* 兑换确认弹窗 */
.exchange-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
  border-radius: 50%;
  background: #f5f5f5;
}

.modal-content {
  padding: 30rpx;
}

.selected-product {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.product-avatar {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  background: #fff;
  border-radius: 16rpx;
}

.product-detail {
  flex: 1;
}

.product-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.product-description {
  display: block;
  font-size: 24rpx;
  color: #666;
}

.points-detail {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.points-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.points-row:last-child {
  margin-bottom: 0;
}

.points-label {
  font-size: 26rpx;
  color: #666;
}

.points-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.points-num.minus {
  color: #ef4444;
}

.points-num.warning {
  color: #f59e0b;
}

.points-divider {
  height: 1rpx;
  background: #e5e5e5;
  margin: 16rpx 0;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn,
.confirm-btn,
.disabled-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.disabled-btn {
  background: #ccc;
  color: #999;
}

.cancel-btn::after,
.confirm-btn::after,
.disabled-btn::after {
  border: none;
}

/* 兑换成功弹窗 */
.success-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 1001;
  text-align: center;
}

.success-icon {
  font-size: 100rpx;
  margin: 40rpx 0 20rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.success-content {
  padding: 0 40rpx;
}

.code-display {
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.code-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.code-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 8rpx;
  font-family: monospace;
}

.code-tip {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.code-tip .highlight {
  color: #f59e0b;
  font-weight: bold;
}

.success-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx 40rpx;
}

.save-btn,
.done-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.save-btn {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #fff;
}

.done-btn {
  background: #f5f5f5;
  color: #666;
}

.save-btn::after,
.done-btn::after {
  border: none;
}
