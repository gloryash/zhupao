/* 页面容器 - 渐变活力橙色主题 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5E6 0%, #FFFFFF 100%);
  padding: 40rpx 30rpx;
}

/* 页面标题 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

/* 表单区域 */
.form-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(255, 140, 0, 0.1);
}

/* 表单项 */
.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.required {
  color: #FF4500;
  margin-left: 8rpx;
}

.optional {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
  margin-left: 10rpx;
}

/* 单选框组 */
.radio-group {
  display: flex;
  gap: 40rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  color: #666;
}

/* 输入框 */
.input {
  width: 100%;
  height: 96rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid #EEE;
}

.input:focus {
  outline: none;
  border-color: #FF6B00;
}

/* 选择器 */
.picker {
  width: 100%;
  height: 96rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  line-height: 96rpx;
  color: #333;
  border: 1rpx solid #EEE;
  box-sizing: border-box;
}

/* 文本域 */
.textarea {
  width: 100%;
  min-height: 200rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid #EEE;
}

.textarea:focus {
  outline: none;
  border-color: #FF6B00;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  display: block;
  margin-top: 10rpx;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #FF8C00 0%, #FF4500 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  margin-top: 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 0, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.9;
}

/* 验证码输入组 */
.code-input-group {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.code-input {
  flex: 1;
}

.code-btn {
  width: 200rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
  padding: 0;
  line-height: 80rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 0, 0.2);
}

.code-btn[disabled] {
  background: #EEE;
  color: #999;
  box-shadow: none;
}

.code-btn::after {
  border: none;
}

/* 已验证提示 */
.verified-tip {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #FFF5E0;
  border-radius: 12rpx;
  border: 1rpx solid #FFD699;
}

.verified-icon {
  color: #FF6B00;
  font-size: 32rpx;
  margin-right: 10rpx;
}

.verified-text {
  color: #FF6B00;
  font-size: 28rpx;
}

/* 性别选择器 */
.gender-selector {
  display: flex;
  gap: 30rpx;
}

.gender-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 96rpx;
  background-color: #F8F8F8;
  border: 2rpx solid #EEE;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.gender-option.active {
  background-color: #FFF5E6;
  border-color: #FF6B00;
}

.gender-icon {
  font-size: 40rpx;
}

.gender-label {
  font-size: 30rpx;
  color: #666;
}

.gender-option.active .gender-label {
  color: #FF6B00;
  font-weight: bold;
}
